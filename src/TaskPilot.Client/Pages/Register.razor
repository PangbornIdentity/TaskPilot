@page "/register"
@inject AuthService AuthService
@inject NavigationManager NavigationManager

<PageTitle>Register — TaskPilot</PageTitle>

<MudContainer MaxWidth="MaxWidth.Small" Class="d-flex align-center justify-center" Style="min-height: 100vh;">
    <MudPaper Elevation="4" Class="pa-8" Style="width: 100%; max-width: 420px;">
        <MudStack AlignItems="AlignItems.Center" Class="mb-6">
            <MudIcon Icon="@Icons.Material.Filled.RocketLaunch" Color="Color.Primary" Style="font-size: 3rem;" />
            <MudText Typo="Typo.h4" Style="font-family: 'Plus Jakarta Sans', sans-serif; font-weight: 700;">TaskPilot</MudText>
            <MudText Typo="Typo.body2" Color="Color.Secondary">Create your account</MudText>
        </MudStack>

        @if (!string.IsNullOrEmpty(_errorMessage))
        {
            <MudAlert Severity="Severity.Error" Class="mb-4">@_errorMessage</MudAlert>
        }

        <MudForm @ref="_form" @bind-IsValid="_isValid">
            <MudTextField @bind-Value="_email" Label="Email" InputType="InputType.Email"
                          Required="true" RequiredError="Email is required"
                          Variant="Variant.Outlined" Class="mb-4" FullWidth="true" />
            <MudTextField @bind-Value="_password" Label="Password" InputType="InputType.Password"
                          Required="true" RequiredError="Password is required"
                          MinLength="6" MinLengthError="Password must be at least 6 characters"
                          Variant="Variant.Outlined" Class="mb-4" FullWidth="true" />
            <MudTextField @bind-Value="_confirmPassword" Label="Confirm Password" InputType="InputType.Password"
                          Required="true" RequiredError="Please confirm your password"
                          Variant="Variant.Outlined" Class="mb-6" FullWidth="true" />
            <MudButton Variant="Variant.Filled" Color="Color.Primary" FullWidth="true"
                       OnClick="HandleRegister" Disabled="_loading" Size="Size.Large">
                @if (_loading)
                {
                    <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
                }
                Create Account
            </MudButton>
        </MudForm>

        <MudDivider Class="my-4" />
        <MudText Typo="Typo.body2" Align="Align.Center">
            Already have an account?
            <MudLink Href="/login">Sign in</MudLink>
        </MudText>
    </MudPaper>
</MudContainer>

@code {
    private MudForm _form = null!;
    private string _email = string.Empty;
    private string _password = string.Empty;
    private string _confirmPassword = string.Empty;
    private bool _isValid;
    private bool _loading;
    private string _errorMessage = string.Empty;

    protected override void OnInitialized()
    {
        if (AuthService.IsAuthenticated)
        {
            NavigationManager.NavigateTo("/");
        }
    }

    private async Task HandleRegister()
    {
        await _form.ValidateAsync();
        if (!_isValid) return;

        if (_password != _confirmPassword)
        {
            _errorMessage = "Passwords do not match.";
            return;
        }

        _loading = true;
        _errorMessage = string.Empty;
        StateHasChanged();

        var success = await AuthService.RegisterAsync(_email, _password);
        if (success)
        {
            NavigationManager.NavigateTo("/");
        }
        else
        {
            _errorMessage = "Registration failed. The email may already be in use.";
        }

        _loading = false;
        StateHasChanged();
    }
}
