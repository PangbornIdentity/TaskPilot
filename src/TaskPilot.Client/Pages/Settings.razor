@page "/settings"
@inject ApiKeyHttpService ApiKeyService
@inject ThemeService ThemeService
@inject AuthService AuthService
@inject ToastService Toast
@inject IJSRuntime JS

<PageTitle>Settings — TaskPilot</PageTitle>

<MudText Typo="Typo.h4" Class="mb-6" Style="font-family: 'Plus Jakarta Sans', sans-serif; font-weight: 700;">Settings</MudText>

<MudTabs Rounded="true" ApplyEffectsToContainer="true" Elevation="2" PanelClass="pa-4">

    <!-- API Keys Tab -->
    <MudTabPanel Text="API Keys" Icon="@Icons.Material.Filled.Key">
        <MudText Typo="Typo.h6" Class="mb-3">Generate API Key</MudText>
        <MudStack Row="true" Spacing="2" Class="mb-4">
            <MudTextField @bind-Value="_newKeyName" Label="Key name" Variant="Variant.Outlined"
                          Margin="Margin.Dense" Placeholder="e.g. My App" Style="max-width: 300px;" />
            <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="GenerateKey"
                       Disabled="_generatingKey">Generate</MudButton>
        </MudStack>

        @if (_newKeyResult is not null)
        {
            <MudAlert Severity="Severity.Warning" Class="mb-4">
                <MudText><strong>Copy this key now — it will not be shown again!</strong></MudText>
                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2" Class="mt-2">
                    <MudText Typo="Typo.body2" Style="font-family: monospace; font-size: 0.85em;">@_newKeyResult.PlainTextKey</MudText>
                    <MudIconButton Icon="@Icons.Material.Filled.ContentCopy" Size="Size.Small"
                                   OnClick="@(() => CopyToClipboard(_newKeyResult.PlainTextKey))" />
                </MudStack>
            </MudAlert>
        }

        @if (_loadingKeys)
        {
            <MudProgressLinear Indeterminate="true" />
        }
        else
        {
            <MudTable T="ApiKeyResponse" Items="_apiKeys" Dense="true" Hover="true" Elevation="1">
                <HeaderContent>
                    <MudTh>Name</MudTh>
                    <MudTh>Prefix</MudTh>
                    <MudTh>Created</MudTh>
                    <MudTh>Last Used</MudTh>
                    <MudTh>Status</MudTh>
                    <MudTh>Actions</MudTh>
                </HeaderContent>
                <RowTemplate>
                    <MudTd DataLabel="Name">
                        @if (_renamingId == context.Id)
                        {
                            <MudTextField @bind-Value="_renameValue" Variant="Variant.Outlined" Margin="Margin.Dense"
                                          OnKeyDown="@(e => HandleRenameKey(e, context))"
                                          OnBlur="@(() => _renamingId = null)" />
                        }
                        else
                        {
                            <MudText @ondblclick="@(() => StartRename(context))">@context.Name</MudText>
                        }
                    </MudTd>
                    <MudTd DataLabel="Prefix"><MudText Typo="Typo.body2" Style="font-family: monospace;">@context.KeyPrefix...</MudText></MudTd>
                    <MudTd DataLabel="Created"><MudText Typo="Typo.body2">@context.CreatedDate.ToString("MMM d, yyyy")</MudText></MudTd>
                    <MudTd DataLabel="Last Used">
                        <MudText Typo="Typo.body2">@(context.LastUsedDate?.ToString("MMM d, yyyy") ?? "Never")</MudText>
                    </MudTd>
                    <MudTd DataLabel="Status">
                        <MudChip T="string" Size="Size.Small" Color="@(context.IsActive ? Color.Success : Color.Default)">
                            @(context.IsActive ? "Active" : "Inactive")
                        </MudChip>
                    </MudTd>
                    <MudTd>
                        <MudStack Row="true" Spacing="1">
                            <MudIconButton Icon="@Icons.Material.Filled.Edit" Size="Size.Small"
                                           OnClick="@(() => StartRename(context))" Title="Rename" />
                            @if (context.IsActive)
                            {
                                <MudIconButton Icon="@Icons.Material.Filled.PauseCircle" Size="Size.Small"
                                               OnClick="@(() => DeactivateKey(context))" Title="Deactivate" />
                            }
                            else
                            {
                                <MudIconButton Icon="@Icons.Material.Filled.PlayCircle" Size="Size.Small" Color="Color.Success"
                                               OnClick="@(() => ActivateKey(context))" Title="Activate" />
                            }
                            <MudIconButton Icon="@Icons.Material.Filled.Delete" Size="Size.Small" Color="Color.Error"
                                           OnClick="@(() => RevokeKey(context))" Title="Revoke" />
                        </MudStack>
                    </MudTd>
                </RowTemplate>
            </MudTable>
        }
    </MudTabPanel>

    <!-- Appearance Tab -->
    <MudTabPanel Text="Appearance" Icon="@Icons.Material.Filled.Palette">
        <MudText Typo="Typo.h6" Class="mb-3">Theme</MudText>
        <MudRadioGroup T="ThemeMode" @bind-Value="_selectedThemeMode">
            <MudRadio T="ThemeMode" Value="ThemeMode.Light">Light</MudRadio>
            <MudRadio T="ThemeMode" Value="ThemeMode.Dark">Dark</MudRadio>
            <MudRadio T="ThemeMode" Value="ThemeMode.System">System</MudRadio>
        </MudRadioGroup>
        <MudButton Variant="Variant.Filled" Color="Color.Primary" Class="mt-4"
                   OnClick="SaveTheme">Apply Theme</MudButton>
    </MudTabPanel>

    <!-- Data Export Tab -->
    <MudTabPanel Text="Data Export" Icon="@Icons.Material.Filled.Download">
        <MudText Typo="Typo.h6" Class="mb-2">Export Tasks</MudText>
        <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mb-4">
            Download all your tasks as a CSV file.
        </MudText>
        <MudButton Variant="Variant.Outlined" StartIcon="@Icons.Material.Filled.FileDownload"
                   OnClick="ExportCsv">Export CSV</MudButton>
    </MudTabPanel>

    <!-- Account Tab -->
    <MudTabPanel Text="Account" Icon="@Icons.Material.Filled.Person">
        <MudText Typo="Typo.h6" Class="mb-3">Account Info</MudText>
        @if (AuthService.CurrentUser is not null)
        {
            <MudText Class="mb-4"><strong>Email:</strong> @AuthService.CurrentUser.Email</MudText>
        }

        <MudText Typo="Typo.h6" Class="mb-3">Change Password</MudText>
        <MudForm @ref="_passwordForm" @bind-IsValid="_passwordFormValid" Style="max-width: 400px;">
            <MudTextField @bind-Value="_currentPassword" Label="Current Password"
                          InputType="InputType.Password" Required="true"
                          Variant="Variant.Outlined" Class="mb-3" FullWidth="true" />
            <MudTextField @bind-Value="_newPassword" Label="New Password"
                          InputType="InputType.Password" Required="true"
                          MinLength="6" MinLengthError="Must be at least 6 characters"
                          Variant="Variant.Outlined" Class="mb-3" FullWidth="true" />
            <MudTextField @bind-Value="_confirmNewPassword" Label="Confirm New Password"
                          InputType="InputType.Password" Required="true"
                          Variant="Variant.Outlined" Class="mb-4" FullWidth="true" />
            <MudButton Variant="Variant.Filled" Color="Color.Primary"
                       OnClick="ChangePassword" Disabled="_changingPassword">
                Change Password
            </MudButton>
        </MudForm>
    </MudTabPanel>
</MudTabs>

@code {
    private bool _loadingKeys = true;
    private List<ApiKeyResponse> _apiKeys = new();
    private CreateApiKeyResponse? _newKeyResult;
    private string _newKeyName = string.Empty;
    private bool _generatingKey;

    private Guid? _renamingId;
    private string _renameValue = string.Empty;

    private ThemeMode _selectedThemeMode;

    private MudForm _passwordForm = null!;
    private bool _passwordFormValid;
    private string _currentPassword = string.Empty;
    private string _newPassword = string.Empty;
    private string _confirmNewPassword = string.Empty;
    private bool _changingPassword;

    protected override async Task OnInitializedAsync()
    {
        _selectedThemeMode = ThemeService.Mode;
        await LoadKeysAsync();
    }

    private async Task LoadKeysAsync()
    {
        _loadingKeys = true;
        try
        {
            _apiKeys = await ApiKeyService.GetKeysAsync();
        }
        catch (Exception ex)
        {
            Toast.ShowError($"Failed to load API keys: {ex.Message}");
        }
        finally
        {
            _loadingKeys = false;
            StateHasChanged();
        }
    }

    private async Task GenerateKey()
    {
        if (string.IsNullOrWhiteSpace(_newKeyName)) return;
        _generatingKey = true;
        _newKeyResult = null;
        try
        {
            _newKeyResult = await ApiKeyService.GenerateKeyAsync(new CreateApiKeyRequest(_newKeyName));
            _newKeyName = string.Empty;
            Toast.ShowSuccess("API key generated");
            await LoadKeysAsync();
        }
        catch (Exception ex)
        {
            Toast.ShowError($"Failed to generate key: {ex.Message}");
        }
        finally
        {
            _generatingKey = false;
            StateHasChanged();
        }
    }

    private void StartRename(ApiKeyResponse key)
    {
        _renamingId = key.Id;
        _renameValue = key.Name;
    }

    private async Task HandleRenameKey(KeyboardEventArgs e, ApiKeyResponse key)
    {
        if (e.Key == "Enter") await SaveRename(key);
        else if (e.Key == "Escape") _renamingId = null;
    }

    private async Task SaveRename(ApiKeyResponse key)
    {
        if (string.IsNullOrWhiteSpace(_renameValue)) { _renamingId = null; return; }
        try
        {
            await ApiKeyService.RenameKeyAsync(key.Id, new RenameApiKeyRequest(_renameValue));
            Toast.ShowSuccess("Key renamed");
            _renamingId = null;
            await LoadKeysAsync();
        }
        catch (Exception ex)
        {
            Toast.ShowError($"Failed to rename key: {ex.Message}");
        }
    }

    private async Task ActivateKey(ApiKeyResponse key)
    {
        try
        {
            await ApiKeyService.ActivateKeyAsync(key.Id);
            Toast.ShowSuccess("Key activated");
            await LoadKeysAsync();
        }
        catch (Exception ex)
        {
            Toast.ShowError($"Failed to activate key: {ex.Message}");
        }
    }

    private async Task DeactivateKey(ApiKeyResponse key)
    {
        try
        {
            await ApiKeyService.DeactivateKeyAsync(key.Id);
            Toast.ShowSuccess("Key deactivated");
            await LoadKeysAsync();
        }
        catch (Exception ex)
        {
            Toast.ShowError($"Failed to deactivate key: {ex.Message}");
        }
    }

    private async Task RevokeKey(ApiKeyResponse key)
    {
        try
        {
            await ApiKeyService.RevokeKeyAsync(key.Id);
            Toast.ShowSuccess("Key revoked");
            await LoadKeysAsync();
        }
        catch (Exception ex)
        {
            Toast.ShowError($"Failed to revoke key: {ex.Message}");
        }
    }

    private async Task SaveTheme()
    {
        await ThemeService.SetModeAsync(_selectedThemeMode);
        Toast.ShowSuccess("Theme updated");
    }

    private async Task ExportCsv()
    {
        try
        {
            await JS.InvokeVoidAsync("window.open", "api/v1/tasks?pageSize=9999&format=csv", "_blank");
            Toast.ShowInfo("Export initiated");
        }
        catch (Exception ex)
        {
            Toast.ShowError($"Export failed: {ex.Message}");
        }
    }

    private async Task ChangePassword()
    {
        await _passwordForm.ValidateAsync();
        if (!_passwordFormValid) return;
        if (_newPassword != _confirmNewPassword)
        {
            Toast.ShowError("New passwords do not match.");
            return;
        }
        _changingPassword = true;
        // Password change endpoint would be POST /api/v1/account/change-password
        // For now show info since backend endpoint may not exist in iteration 1
        Toast.ShowInfo("Password change not yet implemented in this iteration.");
        _changingPassword = false;
        StateHasChanged();
    }

    private async Task CopyToClipboard(string text)
    {
        try
        {
            await JS.InvokeVoidAsync("navigator.clipboard.writeText", text);
            Toast.ShowSuccess("Copied to clipboard");
        }
        catch
        {
            Toast.ShowError("Failed to copy. Please copy manually.");
        }
    }
}
