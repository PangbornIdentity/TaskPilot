@page "/audit"
@inject AuditHttpService AuditService
@inject ApiKeyHttpService ApiKeyService
@inject ToastService Toast

<PageTitle>Audit — TaskPilot</PageTitle>

<MudText Typo="Typo.h4" Class="mb-6" Style="font-family: 'Plus Jakarta Sans', sans-serif; font-weight: 700;">Audit Log</MudText>

@if (_loadingSummary)
{
    <SkeletonLoader Type="SkeletonViewType.Cards" />
}
else if (_summary is not null)
{
    <MudGrid Spacing="3" Class="mb-6">
        <MudItem xs="12" sm="6" md="3">
            <MudPaper Elevation="2" Class="pa-4 rounded-lg">
                <MudText Typo="Typo.overline" Color="Color.Secondary">Total Requests</MudText>
                <MudText Typo="Typo.h3" Style="font-weight: 700; color: var(--mud-palette-primary);">@_summary.TotalRequests</MudText>
            </MudPaper>
        </MudItem>
        <MudItem xs="12" sm="6" md="3">
            <MudPaper Elevation="2" Class="pa-4 rounded-lg">
                <MudText Typo="Typo.overline" Color="Color.Secondary">GETs Today</MudText>
                <MudText Typo="Typo.h3" Style="font-weight: 700;">@_summary.GetsToday</MudText>
            </MudPaper>
        </MudItem>
        <MudItem xs="12" sm="6" md="3">
            <MudPaper Elevation="2" Class="pa-4 rounded-lg">
                <MudText Typo="Typo.overline" Color="Color.Secondary">Writes Today</MudText>
                <MudText Typo="Typo.h3" Style="font-weight: 700;">@_summary.WritesToday</MudText>
            </MudPaper>
        </MudItem>
        <MudItem xs="12" sm="6" md="3">
            <MudPaper Elevation="2" Class="pa-4 rounded-lg">
                <MudText Typo="Typo.overline" Color="Color.Secondary">Active API Keys</MudText>
                <MudText Typo="Typo.h3" Style="font-weight: 700;">@_summary.ActiveApiKeys</MudText>
            </MudPaper>
        </MudItem>
    </MudGrid>
}

<!-- Filter Bar -->
<MudPaper Elevation="1" Class="pa-3 mb-4 rounded-lg">
    <MudGrid Spacing="2" AlignItems="AlignItems.Center">
        <MudItem xs="12" md="3">
            <MudSelect T="Guid?" @bind-Value="_filterApiKeyId" Label="API Key"
                       Variant="Variant.Outlined" Margin="Margin.Dense" FullWidth="true" Clearable="true">
                @foreach (var key in _apiKeys)
                {
                    <MudSelectItem T="Guid?" Value="@((Guid?)key.Id)">@key.Name (@key.KeyPrefix...)</MudSelectItem>
                }
            </MudSelect>
        </MudItem>
        <MudItem xs="6" md="2">
            <MudDatePicker @bind-Date="_filterFrom" Label="From" Variant="Variant.Outlined" Margin="Margin.Dense" />
        </MudItem>
        <MudItem xs="6" md="2">
            <MudDatePicker @bind-Date="_filterTo" Label="To" Variant="Variant.Outlined" Margin="Margin.Dense" />
        </MudItem>
        <MudItem xs="6" md="2">
            <MudSelect T="string?" @bind-Value="_filterMethod" Label="Method"
                       Variant="Variant.Outlined" Margin="Margin.Dense" FullWidth="true" Clearable="true">
                <MudSelectItem T="string?" Value="@("GET")">GET</MudSelectItem>
                <MudSelectItem T="string?" Value="@("POST")">POST</MudSelectItem>
                <MudSelectItem T="string?" Value="@("PUT")">PUT</MudSelectItem>
                <MudSelectItem T="string?" Value="@("PATCH")">PATCH</MudSelectItem>
                <MudSelectItem T="string?" Value="@("DELETE")">DELETE</MudSelectItem>
            </MudSelect>
        </MudItem>
        <MudItem xs="6" md="2">
            <MudButton Variant="Variant.Outlined" FullWidth="true" OnClick="ApplyFilters">Apply</MudButton>
        </MudItem>
    </MudGrid>
</MudPaper>

@if (_loading)
{
    <SkeletonLoader Type="SkeletonViewType.Table" />
}
else if (_logs.Count == 0)
{
    <EmptyState Title="No audit logs" Subtitle="API activity will appear here once API keys are used."
                Icon="@Icons.Material.Filled.History" />
}
else
{
    <MudTable T="AuditLogResponse" Items="_logs" Dense="true" Hover="true" Elevation="2">
        <HeaderContent>
            <MudTh>Time</MudTh>
            <MudTh>API Key</MudTh>
            <MudTh>Method</MudTh>
            <MudTh>Endpoint</MudTh>
            <MudTh>Status</MudTh>
            <MudTh>Duration</MudTh>
        </HeaderContent>
        <RowTemplate>
            <MudTd DataLabel="Time">
                <MudText Typo="Typo.body2">@context.Timestamp.ToString("MMM d, HH:mm:ss")</MudText>
            </MudTd>
            <MudTd DataLabel="API Key">
                <MudLink OnClick="@(() => FilterByKey(context.ApiKeyId))">@context.ApiKeyName</MudLink>
            </MudTd>
            <MudTd DataLabel="Method">
                <MudChip T="string" Size="Size.Small" Color="@GetMethodColor(context.HttpMethod)">@context.HttpMethod</MudChip>
            </MudTd>
            <MudTd DataLabel="Endpoint">
                <MudText Typo="Typo.body2">@context.Endpoint</MudText>
            </MudTd>
            <MudTd DataLabel="Status">
                <MudChip T="string" Size="Size.Small" Color="@GetStatusCodeColor(context.ResponseStatusCode)">@context.ResponseStatusCode</MudChip>
            </MudTd>
            <MudTd DataLabel="Duration">
                <MudText Typo="Typo.body2">@context.DurationMs ms</MudText>
            </MudTd>
        </RowTemplate>
    </MudTable>

    @if (_totalPages > 1)
    {
        <MudStack AlignItems="AlignItems.Center" Class="mt-4">
            <MudPagination Count="_totalPages" Selected="_currentPage" SelectedChanged="OnPageChanged" />
        </MudStack>
    }
}

@code {
    private bool _loading = true;
    private bool _loadingSummary = true;
    private List<AuditLogResponse> _logs = new();
    private List<ApiKeyResponse> _apiKeys = new();
    private AuditSummaryResponse? _summary;
    private int _currentPage = 1;
    private int _totalPages = 1;

    private Guid? _filterApiKeyId;
    private DateTime? _filterFrom;
    private DateTime? _filterTo;
    private string? _filterMethod;

    protected override async Task OnInitializedAsync()
    {
        await Task.WhenAll(LoadSummaryAsync(), LoadApiKeysAsync(), LoadLogsAsync());
    }

    private async Task LoadSummaryAsync()
    {
        try
        {
            _summary = await AuditService.GetSummaryAsync();
        }
        catch (Exception ex)
        {
            Toast.ShowError($"Failed to load summary: {ex.Message}");
        }
        finally
        {
            _loadingSummary = false;
            StateHasChanged();
        }
    }

    private async Task LoadApiKeysAsync()
    {
        try
        {
            _apiKeys = await ApiKeyService.GetKeysAsync();
        }
        catch { }
    }

    private async Task LoadLogsAsync()
    {
        _loading = true;
        try
        {
            var queryParams = new AuditQueryParams(
                ApiKeyId: _filterApiKeyId,
                From: _filterFrom,
                To: _filterTo,
                HttpMethod: _filterMethod,
                Page: _currentPage
            );
            var result = await AuditService.GetAuditLogsAsync(queryParams);
            if (result is not null)
            {
                _logs = result.Data.ToList();
                _totalPages = result.Meta.TotalPages;
            }
        }
        catch (Exception ex)
        {
            Toast.ShowError($"Failed to load audit logs: {ex.Message}");
        }
        finally
        {
            _loading = false;
            StateHasChanged();
        }
    }

    private async Task ApplyFilters()
    {
        _currentPage = 1;
        await LoadLogsAsync();
    }

    private async Task OnPageChanged(int page)
    {
        _currentPage = page;
        await LoadLogsAsync();
    }

    private async Task FilterByKey(Guid apiKeyId)
    {
        _filterApiKeyId = apiKeyId;
        _currentPage = 1;
        await LoadLogsAsync();
    }

    private static Color GetMethodColor(string method) => method switch
    {
        "GET" => Color.Info,
        "POST" => Color.Success,
        "PUT" or "PATCH" => Color.Warning,
        "DELETE" => Color.Error,
        _ => Color.Default
    };

    private static Color GetStatusCodeColor(int code) => code switch
    {
        >= 200 and < 300 => Color.Success,
        >= 400 and < 500 => Color.Warning,
        >= 500 => Color.Error,
        _ => Color.Default
    };
}
