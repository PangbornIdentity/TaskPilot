@page "/tasks"
@inject TaskHttpService TaskService
@inject TagHttpService TagService
@inject ToastService Toast
@inject NavigationManager NavigationManager

<PageTitle>Tasks — TaskPilot</PageTitle>

<MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Class="mb-4">
    <MudText Typo="Typo.h4" Style="font-family: 'Plus Jakarta Sans', sans-serif; font-weight: 700;">Tasks</MudText>
    <MudStack Row="true" Spacing="2">
        <MudToggleGroup T="string" @bind-Value="_viewMode" Exclusive="true" Dense="true">
            <MudToggleItem Value="@("list")" Icon="@Icons.Material.Filled.ViewList" />
            <MudToggleItem Value="@("board")" Icon="@Icons.Material.Filled.ViewKanban" />
        </MudToggleGroup>
        <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Add"
                   OnClick="OpenCreateSlideOver">New Task</MudButton>
    </MudStack>
</MudStack>

<!-- Search and Filter Bar -->
<MudPaper Elevation="1" Class="pa-3 mb-4 rounded-lg">
    <MudGrid Spacing="2" AlignItems="AlignItems.Center">
        <MudItem xs="12" md="4">
            <MudTextField @bind-Value="_searchText" Placeholder="Search tasks..."
                          Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search"
                          Clearable="true" Immediate="true" DebounceInterval="300"
                          OnDebounceIntervalElapsed="OnSearchChanged"
                          Variant="Variant.Outlined" Margin="Margin.Dense" FullWidth="true" />
        </MudItem>
        <MudItem xs="6" md="2">
            <MudSelect T="string?" @bind-Value="_filterType" Label="Type"
                       Variant="Variant.Outlined" Margin="Margin.Dense" FullWidth="true" Clearable="true">
                @foreach (var t in TaskTypes.All)
                {
                    <MudSelectItem T="string?" Value="@t">@t</MudSelectItem>
                }
            </MudSelect>
        </MudItem>
        <MudItem xs="6" md="2">
            <MudSelect T="TaskPriority?" @bind-Value="_filterPriority" Label="Priority"
                       Variant="Variant.Outlined" Margin="Margin.Dense" FullWidth="true" Clearable="true">
                @foreach (TaskPriority p in Enum.GetValues(typeof(TaskPriority)))
                {
                    <MudSelectItem T="TaskPriority?" Value="@p">@p</MudSelectItem>
                }
            </MudSelect>
        </MudItem>
        <MudItem xs="6" md="2">
            <MudSelect T="AppTaskStatus?" @bind-Value="_filterStatus" Label="Status"
                       Variant="Variant.Outlined" Margin="Margin.Dense" FullWidth="true" Clearable="true">
                @foreach (AppTaskStatus s in Enum.GetValues(typeof(AppTaskStatus)))
                {
                    <MudSelectItem T="AppTaskStatus?" Value="@s">@s</MudSelectItem>
                }
            </MudSelect>
        </MudItem>
        <MudItem xs="6" md="2">
            <MudButton Variant="Variant.Outlined" FullWidth="true" OnClick="ApplyFilters">Apply</MudButton>
        </MudItem>
    </MudGrid>
</MudPaper>

<!-- Bulk Action Toolbar -->
@if (_selectedIds.Count > 0)
{
    <MudPaper Elevation="2" Class="pa-2 mb-4 rounded-lg" Style="background: var(--mud-palette-primary); color: white;">
        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
            <MudText>@_selectedIds.Count selected</MudText>
            <MudButton Size="Size.Small" Variant="Variant.Filled" Color="Color.Success"
                       OnClick="BulkComplete">Mark Complete</MudButton>
            <MudButton Size="Size.Small" Variant="Variant.Filled" Color="Color.Error"
                       OnClick="BulkDelete">Delete</MudButton>
            <MudSpacer />
            <MudIconButton Icon="@Icons.Material.Filled.Close" Size="Size.Small"
                           OnClick="@(() => _selectedIds.Clear())" />
        </MudStack>
    </MudPaper>
}

@if (_loading)
{
    <SkeletonLoader Type="SkeletonViewType.Table" />
}
else if (_tasks.Count == 0)
{
    <EmptyState Title="No tasks found" Subtitle="Try adjusting your filters or create a new task."
                Icon="@Icons.Material.Filled.CheckCircleOutline"
                ActionLabel="Create Task" OnAction="OpenCreateSlideOver" />
}
else if (_viewMode == "list")
{
    <!-- List View -->
    <MudTable T="TaskResponse" Items="_tasks" Hover="true" Dense="true"
              MultiSelection="true" SelectedItemsChanged="OnSelectedItemsChanged"
              OnRowClick="OnRowClick" RowClass="cursor-pointer">
        <HeaderContent>
            <MudTh>Title</MudTh>
            <MudTh>Type</MudTh>
            <MudTh>Priority</MudTh>
            <MudTh>Status</MudTh>
            <MudTh>Target</MudTh>
            <MudTh>Tags</MudTh>
            <MudTh>Actions</MudTh>
        </HeaderContent>
        <RowTemplate>
            <MudTd DataLabel="Title">
                @if (_editingId == context.Id)
                {
                    <MudTextField @bind-Value="_editingTitle" Immediate="true"
                                  OnKeyDown="@(e => HandleInlineEditKey(e, context))"
                                  OnBlur="@(() => CancelInlineEdit())"
                                  Variant="Variant.Outlined" Margin="Margin.Dense" />
                }
                else
                {
                    <MudText @ondblclick="@(() => StartInlineEdit(context))" Style="cursor: text;">
                        @context.Title
                    </MudText>
                }
            </MudTd>
            <MudTd DataLabel="Type">
                <MudChip T="string" Size="Size.Small">@context.Type</MudChip>
            </MudTd>
            <MudTd DataLabel="Priority">
                <MudChip T="string" Size="Size.Small" Color="@GetPriorityColor(context.Priority)">@context.Priority</MudChip>
            </MudTd>
            <MudTd DataLabel="Status">
                <MudChip T="string" Size="Size.Small" Color="@GetStatusColor(context.Status)">@context.Status</MudChip>
            </MudTd>
            <MudTd DataLabel="Target">
                @if (context.TargetDate.HasValue)
                {
                    <MudText Typo="Typo.body2">@context.TargetDate.Value.ToString("MMM d")</MudText>
                }
                else
                {
                    <MudText Typo="Typo.body2" Color="Color.Secondary">@context.TargetDateType</MudText>
                }
            </MudTd>
            <MudTd DataLabel="Tags">
                @foreach (var tag in context.Tags)
                {
                    <MudChip T="string" Size="Size.Small" Style="@($"background-color:{tag.Color};color:white;")">@tag.Name</MudChip>
                }
            </MudTd>
            <MudTd>
                <MudStack Row="true" Spacing="1">
                    <MudIconButton Icon="@Icons.Material.Filled.Edit" Size="Size.Small"
                                   OnClick="@(() => OpenEditSlideOver(context.Id))" />
                    <MudIconButton Icon="@Icons.Material.Filled.CheckCircle" Size="Size.Small" Color="Color.Success"
                                   OnClick="@(() => CompleteTask(context))"
                                   Disabled="@(context.Status == AppTaskStatus.Completed)" />
                    <MudIconButton Icon="@Icons.Material.Filled.Delete" Size="Size.Small" Color="Color.Error"
                                   OnClick="@(() => DeleteTask(context))" />
                </MudStack>
            </MudTd>
        </RowTemplate>
    </MudTable>
}
else
{
    <!-- Board View (Kanban) -->
    <MudGrid Spacing="3">
        @foreach (AppTaskStatus status in Enum.GetValues(typeof(AppTaskStatus)))
        {
            var statusTasks = _tasks.Where(t => t.Status == status).ToList();
            <MudItem xs="12" sm="6" md="4" lg="2">
                <MudPaper Elevation="2" Class="pa-3 rounded-lg" Style="min-height: 200px;">
                    <MudStack Row="true" AlignItems="AlignItems.Center" Class="mb-3">
                        <MudChip T="string" Size="Size.Small" Color="@GetStatusColor(status)">@status</MudChip>
                        <MudText Typo="Typo.caption">(@statusTasks.Count)</MudText>
                    </MudStack>
                    @foreach (var task in statusTasks)
                    {
                        <MudPaper Elevation="1" Class="pa-2 mb-2 rounded" @onclick="@(() => OpenEditSlideOver(task.Id))"
                                  Style="cursor: pointer;">
                            <MudText Typo="Typo.body2" Style="font-weight: 500;">@task.Title</MudText>
                            <MudStack Row="true" Class="mt-1" Spacing="1">
                                <MudChip T="string" Size="Size.Small" Color="@GetPriorityColor(task.Priority)">@task.Priority</MudChip>
                            </MudStack>
                        </MudPaper>
                    }
                </MudPaper>
            </MudItem>
        }
    </MudGrid>
}

<!-- Pagination -->
@if (_totalPages > 1)
{
    <MudStack AlignItems="AlignItems.Center" Class="mt-4">
        <MudPagination Count="_totalPages" Selected="_currentPage" SelectedChanged="OnPageChanged" />
    </MudStack>
}

<!-- Task Slide-Over -->
@if (_slideOverOpen)
{
    <TaskSlideOver TaskId="_slideOverTaskId" OnSaved="OnTaskSaved" OnClosed="CloseSlideOver" />
}

@code {
    private bool _loading = true;
    private string _viewMode = "list";
    private List<TaskResponse> _tasks = new();
    private HashSet<Guid> _selectedIds = new();
    private int _currentPage = 1;
    private int _totalPages = 1;
    private string _searchText = string.Empty;
    private string? _filterType;
    private TaskPriority? _filterPriority;
    private AppTaskStatus? _filterStatus;

    private bool _slideOverOpen;
    private Guid? _slideOverTaskId;

    private Guid? _editingId;
    private string _editingTitle = string.Empty;

    protected override async Task OnInitializedAsync()
    {
        await LoadTasksAsync();
    }

    private async Task LoadTasksAsync()
    {
        _loading = true;
        try
        {
            var queryParams = new TaskQueryParams(
                Status: _filterStatus,
                Type: _filterType,
                Priority: _filterPriority,
                Search: _searchText,
                Page: _currentPage
            );
            var result = await TaskService.GetTasksAsync(queryParams);
            if (result is not null)
            {
                _tasks = result.Data.ToList();
                _totalPages = result.Meta.TotalPages;
            }
        }
        catch (Exception ex)
        {
            Toast.ShowError($"Failed to load tasks: {ex.Message}");
        }
        finally
        {
            _loading = false;
            StateHasChanged();
        }
    }

    private void OnSelectedItemsChanged(HashSet<TaskResponse> selected)
    {
        _selectedIds = selected.Select(t => t.Id).ToHashSet();
        StateHasChanged();
    }

    private async Task OnSearchChanged()
    {
        _currentPage = 1;
        await LoadTasksAsync();
    }

    private async Task ApplyFilters()
    {
        _currentPage = 1;
        await LoadTasksAsync();
    }

    private async Task OnPageChanged(int page)
    {
        _currentPage = page;
        await LoadTasksAsync();
    }

    private void OnRowClick(TableRowClickEventArgs<TaskResponse> args)
    {
        if (args.Item is not null)
        {
            NavigationManager.NavigateTo($"/tasks/{args.Item.Id}");
        }
    }

    private void OpenCreateSlideOver()
    {
        _slideOverTaskId = null;
        _slideOverOpen = true;
    }

    private void OpenEditSlideOver(Guid id)
    {
        _slideOverTaskId = id;
        _slideOverOpen = true;
    }

    private void CloseSlideOver()
    {
        _slideOverOpen = false;
        StateHasChanged();
    }

    private async Task OnTaskSaved()
    {
        _slideOverOpen = false;
        await LoadTasksAsync();
    }

    private void StartInlineEdit(TaskResponse task)
    {
        _editingId = task.Id;
        _editingTitle = task.Title;
    }

    private void CancelInlineEdit()
    {
        _editingId = null;
        _editingTitle = string.Empty;
    }

    private async Task HandleInlineEditKey(KeyboardEventArgs e, TaskResponse task)
    {
        if (e.Key == "Enter")
        {
            await SaveInlineEdit(task);
        }
        else if (e.Key == "Escape")
        {
            CancelInlineEdit();
        }
    }

    private async Task SaveInlineEdit(TaskResponse task)
    {
        if (!string.IsNullOrWhiteSpace(_editingTitle) && _editingTitle != task.Title)
        {
            try
            {
                var patch = new PatchTaskRequest(Title: _editingTitle);
                await TaskService.PatchTaskAsync(task.Id, patch);
                Toast.ShowSuccess("Task updated");
                await LoadTasksAsync();
            }
            catch (Exception ex)
            {
                Toast.ShowError($"Failed to update task: {ex.Message}");
            }
        }
        CancelInlineEdit();
    }

    private async Task CompleteTask(TaskResponse task)
    {
        try
        {
            await TaskService.CompleteTaskAsync(task.Id, new CompleteTaskRequest());
            Toast.ShowSuccess($"'{task.Title}' completed!");
            await LoadTasksAsync();
        }
        catch (Exception ex)
        {
            Toast.ShowError($"Failed to complete task: {ex.Message}");
        }
    }

    private async Task DeleteTask(TaskResponse task)
    {
        try
        {
            await TaskService.DeleteTaskAsync(task.Id);
            Toast.ShowUndo($"'{task.Title}' deleted", async () =>
            {
                // Undo not easily reversible via soft-delete endpoint, so just reload
                await LoadTasksAsync();
            });
            await LoadTasksAsync();
        }
        catch (Exception ex)
        {
            Toast.ShowError($"Failed to delete task: {ex.Message}");
        }
    }

    private async Task BulkComplete()
    {
        foreach (var id in _selectedIds.ToList())
        {
            try
            {
                await TaskService.CompleteTaskAsync(id, new CompleteTaskRequest());
            }
            catch { }
        }
        _selectedIds.Clear();
        Toast.ShowSuccess("Selected tasks marked complete");
        await LoadTasksAsync();
    }

    private async Task BulkDelete()
    {
        foreach (var id in _selectedIds.ToList())
        {
            try
            {
                await TaskService.DeleteTaskAsync(id);
            }
            catch { }
        }
        _selectedIds.Clear();
        Toast.ShowSuccess("Selected tasks deleted");
        await LoadTasksAsync();
    }

    private static Color GetPriorityColor(TaskPriority priority) => priority switch
    {
        TaskPriority.Critical => Color.Error,
        TaskPriority.High => Color.Warning,
        TaskPriority.Medium => Color.Info,
        TaskPriority.Low => Color.Default,
        _ => Color.Default
    };

    private static Color GetStatusColor(AppTaskStatus status) => status switch
    {
        AppTaskStatus.NotStarted => Color.Default,
        AppTaskStatus.InProgress => Color.Info,
        AppTaskStatus.Blocked => Color.Error,
        AppTaskStatus.Completed => Color.Success,
        AppTaskStatus.Cancelled => Color.Dark,
        _ => Color.Default
    };
}
