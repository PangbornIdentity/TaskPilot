@inject TaskHttpService TaskService
@inject TagHttpService TagService
@inject ToastService Toast

<div class="slide-over-overlay" @onclick="HandleOverlayClick">
    <div class="slide-over-panel" @onclick:stopPropagation="true">
        <MudPaper Elevation="8" Class="h-100 d-flex flex-column" Style="height: 100vh; overflow-y: auto;">
            <!-- Header -->
            <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Class="pa-4" Style="border-bottom: 1px solid var(--mud-palette-divider);">
                <MudText Typo="Typo.h6" Style="font-weight: 600;">@(TaskId.HasValue ? "Edit Task" : "New Task")</MudText>
                <MudIconButton Icon="@Icons.Material.Filled.Close" OnClick="HandleClose" />
            </MudStack>

            <!-- Form -->
            <div class="flex-grow-1 pa-4" style="overflow-y: auto;">
                @if (_loadingTask)
                {
                    <MudProgressLinear Indeterminate="true" Class="mb-4" />
                }

                <MudForm @ref="_form" @bind-IsValid="_isValid">
                    <MudTextField @bind-Value="_model.Title" Label="Title" Required="true"
                                  RequiredError="Title is required"
                                  Variant="Variant.Outlined" Class="mb-4" FullWidth="true" />

                    <MudTextField @bind-Value="_model.Description" Label="Description"
                                  Lines="4" Variant="Variant.Outlined" Class="mb-4" FullWidth="true"
                                  Placeholder="Markdown supported..." />

                    <MudGrid Spacing="3" Class="mb-4">
                        <MudItem xs="12" sm="6">
                            <MudSelect T="string" @bind-Value="_model.Type" Label="Type"
                                       Required="true" Variant="Variant.Outlined" FullWidth="true">
                                @foreach (var t in TaskTypes.All)
                                {
                                    <MudSelectItem T="string" Value="@t">@t</MudSelectItem>
                                }
                            </MudSelect>
                        </MudItem>
                        <MudItem xs="12" sm="6">
                            <MudSelect T="TaskPriority" @bind-Value="_model.Priority" Label="Priority"
                                       Variant="Variant.Outlined" FullWidth="true">
                                @foreach (TaskPriority p in Enum.GetValues(typeof(TaskPriority)))
                                {
                                    <MudSelectItem T="TaskPriority" Value="@p">@p</MudSelectItem>
                                }
                            </MudSelect>
                        </MudItem>
                        <MudItem xs="12" sm="6">
                            <MudSelect T="AppTaskStatus" @bind-Value="_model.Status" Label="Status"
                                       Variant="Variant.Outlined" FullWidth="true">
                                @foreach (AppTaskStatus s in Enum.GetValues(typeof(AppTaskStatus)))
                                {
                                    <MudSelectItem T="AppTaskStatus" Value="@s">@s</MudSelectItem>
                                }
                            </MudSelect>
                        </MudItem>
                        <MudItem xs="12" sm="6">
                            <MudSelect T="TargetDateType" @bind-Value="_model.TargetDateType" Label="Target Date Type"
                                       Variant="Variant.Outlined" FullWidth="true">
                                @foreach (TargetDateType t in Enum.GetValues(typeof(TargetDateType)))
                                {
                                    <MudSelectItem T="TargetDateType" Value="@t">@t</MudSelectItem>
                                }
                            </MudSelect>
                        </MudItem>
                    </MudGrid>

                    @if (_model.TargetDateType == TargetDateType.SpecificDay)
                    {
                        <MudDatePicker @bind-Date="_targetDate" Label="Target Date"
                                       Variant="Variant.Outlined" Class="mb-4" FullWidth="true" />
                    }

                    <MudStack Row="true" AlignItems="AlignItems.Center" Class="mb-4">
                        <MudSwitch @bind-Value="_model.IsRecurring" Color="Color.Primary" />
                        <MudText>Recurring task</MudText>
                    </MudStack>

                    @if (_model.IsRecurring)
                    {
                        <MudSelect T="RecurrencePattern" @bind-Value="_recurrencePattern" Label="Recurrence Pattern"
                                   Variant="Variant.Outlined" Class="mb-4" FullWidth="true">
                            @foreach (RecurrencePattern rp in Enum.GetValues(typeof(RecurrencePattern)))
                            {
                                <MudSelectItem T="RecurrencePattern" Value="@rp">@rp</MudSelectItem>
                            }
                        </MudSelect>
                    }

                    <!-- Tags -->
                    <MudText Typo="Typo.body2" Class="mb-2" Style="font-weight: 500;">Tags</MudText>
                    <MudStack Row="true" Wrap="Wrap.Wrap" Spacing="1" Class="mb-3">
                        @foreach (var tag in _availableTags)
                        {
                            var isSelected = _selectedTagIds.Contains(tag.Id);
                            <MudChip T="string" Size="Size.Small"
                                     Style="@($"background-color:{(isSelected ? tag.Color : "transparent")};color:{(isSelected ? "white" : "inherit")};border:1px solid {tag.Color}; cursor:pointer;")"
                                     OnClick="@(() => ToggleTag(tag.Id))">@tag.Name</MudChip>
                        }
                    </MudStack>

                    <!-- Create new tag -->
                    <MudExpansionPanel Text="+ Add new tag" Class="mb-4">
                        <MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center">
                            <MudTextField @bind-Value="_newTagName" Label="Tag name" Variant="Variant.Outlined"
                                          Margin="Margin.Dense" Style="max-width: 180px;" />
                            <MudColorPicker @bind-Text="_newTagColor" Label="Color"
                                            Variant="Variant.Outlined" Margin="Margin.Dense"
                                            DisableAlpha="true" DisableModeSwitch="true" />
                            <MudButton Variant="Variant.Filled" Color="Color.Primary" Size="Size.Small"
                                       OnClick="CreateTag">Add</MudButton>
                        </MudStack>
                    </MudExpansionPanel>

                    @if (TaskId.HasValue && _existingTask?.Status == AppTaskStatus.Completed)
                    {
                        <MudTextField @bind-Value="_model.ResultAnalysis" Label="Result Analysis"
                                      Lines="3" Variant="Variant.Outlined" Class="mb-4" FullWidth="true"
                                      Placeholder="What was accomplished?" />
                    }
                </MudForm>
            </div>

            <!-- Footer -->
            <MudStack Row="true" Justify="Justify.FlexEnd" Spacing="2" Class="pa-4" Style="border-top: 1px solid var(--mud-palette-divider);">
                <MudButton Variant="Variant.Outlined" OnClick="HandleClose">Cancel</MudButton>
                @if (!TaskId.HasValue)
                {
                    <MudButton Variant="Variant.Outlined" Color="Color.Primary"
                               OnClick="SaveAndCreateAnother" Disabled="_saving">
                        Save &amp; Create Another
                    </MudButton>
                }
                <MudButton Variant="Variant.Filled" Color="Color.Primary"
                           OnClick="Save" Disabled="_saving">
                    @if (_saving)
                    {
                        <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
                    }
                    Save
                </MudButton>
            </MudStack>
        </MudPaper>
    </div>
</div>

@code {
    [Parameter] public Guid? TaskId { get; set; }
    [Parameter] public EventCallback OnSaved { get; set; }
    [Parameter] public EventCallback OnClosed { get; set; }

    private MudForm _form = null!;
    private bool _isValid;
    private bool _saving;
    private bool _loadingTask;

    private TaskFormModel _model = new();
    private TaskResponse? _existingTask;
    private DateTime? _targetDate;
    private RecurrencePattern _recurrencePattern = RecurrencePattern.Weekly;

    private List<TagResponse> _availableTags = new();
    private HashSet<Guid> _selectedTagIds = new();

    private string _newTagName = string.Empty;
    private string _newTagColor = "#6255EC";

    protected override async Task OnInitializedAsync()
    {
        await LoadTagsAsync();
        if (TaskId.HasValue)
        {
            await LoadExistingTaskAsync();
        }
        else
        {
            _model = new TaskFormModel
            {
                Type = TaskTypes.Work,
                Priority = TaskPriority.Medium,
                Status = AppTaskStatus.NotStarted,
                TargetDateType = TargetDateType.ThisWeek
            };
        }
    }

    private async Task LoadTagsAsync()
    {
        try
        {
            _availableTags = await TagService.GetTagsAsync();
        }
        catch { }
    }

    private async Task LoadExistingTaskAsync()
    {
        _loadingTask = true;
        try
        {
            _existingTask = await TaskService.GetTaskByIdAsync(TaskId!.Value);
            if (_existingTask is not null)
            {
                _model = new TaskFormModel
                {
                    Title = _existingTask.Title,
                    Description = _existingTask.Description,
                    Type = _existingTask.Type,
                    Priority = _existingTask.Priority,
                    Status = _existingTask.Status,
                    TargetDateType = _existingTask.TargetDateType,
                    IsRecurring = _existingTask.IsRecurring,
                    ResultAnalysis = _existingTask.ResultAnalysis
                };
                _targetDate = _existingTask.TargetDate;
                _recurrencePattern = _existingTask.RecurrencePattern ?? RecurrencePattern.Weekly;
                _selectedTagIds = _existingTask.Tags.Select(t => t.Id).ToHashSet();
            }
        }
        catch (Exception ex)
        {
            Toast.ShowError($"Failed to load task: {ex.Message}");
        }
        finally
        {
            _loadingTask = false;
            StateHasChanged();
        }
    }

    private void ToggleTag(Guid tagId)
    {
        if (!_selectedTagIds.Remove(tagId))
            _selectedTagIds.Add(tagId);
        StateHasChanged();
    }

    private async Task CreateTag()
    {
        if (string.IsNullOrWhiteSpace(_newTagName)) return;
        try
        {
            var tag = await TagService.CreateTagAsync(new CreateTagRequest(_newTagName, _newTagColor));
            if (tag is not null)
            {
                _availableTags.Add(tag);
                _selectedTagIds.Add(tag.Id);
                _newTagName = string.Empty;
                Toast.ShowSuccess("Tag created");
                StateHasChanged();
            }
        }
        catch (Exception ex)
        {
            Toast.ShowError($"Failed to create tag: {ex.Message}");
        }
    }

    private async Task Save()
    {
        await _form.ValidateAsync();
        if (!_isValid) return;
        _saving = true;
        try
        {
            await SaveInternal();
            await OnSaved.InvokeAsync();
        }
        catch (Exception ex)
        {
            Toast.ShowError($"Failed to save task: {ex.Message}");
        }
        finally
        {
            _saving = false;
            StateHasChanged();
        }
    }

    private async Task SaveAndCreateAnother()
    {
        await _form.ValidateAsync();
        if (!_isValid) return;
        _saving = true;
        try
        {
            await SaveInternal();
            Toast.ShowSuccess("Task saved! Create another.");
            ResetForm();
        }
        catch (Exception ex)
        {
            Toast.ShowError($"Failed to save task: {ex.Message}");
        }
        finally
        {
            _saving = false;
            StateHasChanged();
        }
    }

    private async Task SaveInternal()
    {
        if (TaskId.HasValue)
        {
            var request = new UpdateTaskRequest(
                Title: _model.Title,
                Description: _model.Description,
                Type: _model.Type,
                Priority: _model.Priority,
                Status: _model.Status,
                TargetDateType: _model.TargetDateType,
                TargetDate: _targetDate,
                IsRecurring: _model.IsRecurring,
                RecurrencePattern: _model.IsRecurring ? _recurrencePattern : null,
                TagIds: _selectedTagIds.ToList()
            );
            await TaskService.UpdateTaskAsync(TaskId.Value, request);
            Toast.ShowSuccess("Task updated");
        }
        else
        {
            var request = new CreateTaskRequest(
                Title: _model.Title,
                Description: _model.Description,
                Type: _model.Type,
                Priority: _model.Priority,
                Status: _model.Status,
                TargetDateType: _model.TargetDateType,
                TargetDate: _targetDate,
                IsRecurring: _model.IsRecurring,
                RecurrencePattern: _model.IsRecurring ? _recurrencePattern : null,
                TagIds: _selectedTagIds.ToList()
            );
            await TaskService.CreateTaskAsync(request);
            Toast.ShowSuccess("Task created");
        }
    }

    private void ResetForm()
    {
        _model = new TaskFormModel
        {
            Type = TaskTypes.Work,
            Priority = TaskPriority.Medium,
            Status = AppTaskStatus.NotStarted,
            TargetDateType = TargetDateType.ThisWeek
        };
        _targetDate = null;
        _selectedTagIds.Clear();
        _form.ResetAsync();
    }

    private async Task HandleClose()
    {
        await OnClosed.InvokeAsync();
    }

    private async Task HandleOverlayClick()
    {
        await OnClosed.InvokeAsync();
    }

    private class TaskFormModel
    {
        public string Title { get; set; } = string.Empty;
        public string? Description { get; set; }
        public string Type { get; set; } = TaskTypes.Work;
        public TaskPriority Priority { get; set; } = TaskPriority.Medium;
        public AppTaskStatus Status { get; set; } = AppTaskStatus.NotStarted;
        public TargetDateType TargetDateType { get; set; } = TargetDateType.ThisWeek;
        public bool IsRecurring { get; set; }
        public string? ResultAnalysis { get; set; }
    }
}
