@namespace TaskPilot.Client.Components.Common

<MudStack AlignItems="AlignItems.Center" Justify="Justify.Center" Class="py-12">
    <MudIcon Icon="@Icon" Style="font-size: 4rem; color: var(--mud-palette-action-disabled);" />
    <MudText Typo="Typo.h6" Class="mt-3" Style="font-weight: 600;">@Title</MudText>
    @if (!string.IsNullOrEmpty(Subtitle))
    {
        <MudText Typo="Typo.body2" Color="Color.Secondary" Align="Align.Center" Style="max-width: 360px;">@Subtitle</MudText>
    }
    @if (!string.IsNullOrEmpty(ActionLabel) && OnAction.HasDelegate)
    {
        <MudButton Variant="Variant.Filled" Color="Color.Primary" Class="mt-4"
                   OnClick="OnAction">@ActionLabel</MudButton>
    }
</MudStack>

@code {
    [Parameter] public string Title { get; set; } = "Nothing here";
    [Parameter] public string? Subtitle { get; set; }
    [Parameter] public string Icon { get; set; } = Icons.Material.Filled.Inbox;
    [Parameter] public string? ActionLabel { get; set; }
    [Parameter] public EventCallback OnAction { get; set; }
}
