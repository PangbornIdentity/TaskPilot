@inject TaskHttpService TaskService
@inject ToastService Toast

<div class="quick-add-bar">
    <MudTextField @bind-Value="_title"
                  Placeholder="Quick add task... (Enter to save, Tab to open full form)"
                  Variant="Variant.Outlined"
                  Margin="Margin.Dense"
                  Adornment="Adornment.Start"
                  AdornmentIcon="@Icons.Material.Filled.Add"
                  Style="max-width: 500px; min-width: 280px;"
                  OnKeyDown="HandleKeyDown" />
</div>

@if (_slideOverOpen)
{
    <TaskSlideOver TaskId="null" OnSaved="OnSlideOverSaved" OnClosed="@(() => _slideOverOpen = false)"
                   @ref="_slideOver" />
}

@code {
    private string _title = string.Empty;
    private bool _slideOverOpen;
    private TaskSlideOver? _slideOver;

    private async Task HandleKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter" && !string.IsNullOrWhiteSpace(_title))
        {
            await QuickCreate();
        }
        else if (e.Key == "Tab" && !string.IsNullOrWhiteSpace(_title))
        {
            OpenSlideOver();
        }
    }

    private async Task QuickCreate()
    {
        var title = _title.Trim();
        _title = string.Empty;
        try
        {
            await TaskService.CreateTaskAsync(new CreateTaskRequest(
                Title: title,
                Description: null,
                Type: TaskTypes.Work,
                Priority: TaskPriority.Medium,
                Status: AppTaskStatus.NotStarted,
                TargetDateType: TargetDateType.ThisWeek,
                TargetDate: null,
                IsRecurring: false,
                RecurrencePattern: null,
                TagIds: null
            ));
            Toast.ShowSuccess($"Task '{title}' created");
        }
        catch (Exception ex)
        {
            Toast.ShowError($"Failed to create task: {ex.Message}");
        }
    }

    private void OpenSlideOver()
    {
        _slideOverOpen = true;
        StateHasChanged();
    }

    private void OnSlideOverSaved()
    {
        _slideOverOpen = false;
        _title = string.Empty;
        StateHasChanged();
    }
}
