@page "/tasks"
@model TaskPilot.Pages.Tasks.TasksIndexModel
@using TaskPilot.Models.Enums
@{
    ViewData["Title"] = "Tasks";
    var isBoard = Model.View == "board";
    var isIncomplete = Model.View == "incomplete";
    var nowUtc = DateTime.UtcNow;

    // Build a route-values dict that preserves every active filter, plus any per-link overrides.
    // Url.Page emits properly URL-encoded query strings AND collapses null values, so we don't
    // have to special-case empty filters.
    object FilterRoute(string? viewOverride = null, Area? areaOverride = null, bool keepArea = true)
        => new
        {
            view = viewOverride ?? Model.View,
            search = Model.Search,
            status = Model.StatusFilter,
            priority = Model.PriorityFilter,
            area = keepArea ? (areaOverride ?? Model.AreaFilter) : areaOverride,
            taskTypeId = Model.TaskTypeIdFilter,
            tagIds = Model.TagIdFilter,
            overdue = Model.OverdueFilter ? (bool?)true : null
        };
}

<div class="tp-page-header">
    <div>
        <h1 class="tp-page-title">Tasks</h1>
        <p class="tp-page-subtitle">@Model.TotalCount task@(Model.TotalCount != 1 ? "s" : "") found</p>
    </div>
    <button class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#taskModal">
        <i class="bi bi-plus-lg me-1"></i> New Task
    </button>
</div>

<!-- Area filter -->
<div class="tp-area-filter btn-group mb-3" role="group">
    <a href="@Url.Page("/Tasks/Index", FilterRoute(areaOverride: null, keepArea: false))"
       class="btn btn-sm @(Model.AreaFilter == null ? "btn-primary" : "btn-outline-secondary")">All</a>
    <a href="@Url.Page("/Tasks/Index", FilterRoute(areaOverride: Area.Personal, keepArea: false))"
       class="btn btn-sm @(Model.AreaFilter == Area.Personal ? "btn-primary" : "btn-outline-secondary")">Personal</a>
    <a href="@Url.Page("/Tasks/Index", FilterRoute(areaOverride: Area.Work, keepArea: false))"
       class="btn btn-sm @(Model.AreaFilter == Area.Work ? "btn-primary" : "btn-outline-secondary")">Work</a>
</div>

<!-- Filters -->
<div class="tp-filters">
    <div class="tp-search">
        <i class="bi bi-search tp-search-icon"></i>
        <input type="text" id="searchInput" placeholder="Search tasks..."
               value="@Model.Search"
               hx-get="/tasks"
               hx-trigger="keyup changed delay:400ms"
               hx-target="#task-container"
               hx-include="#filterForm"
               hx-vals='{"handler": "List"}'
               name="search" />
    </div>

    <form id="filterForm" method="get" action="/tasks" class="d-flex gap-2 align-items-center flex-wrap">
        <input type="hidden" name="view" value="@Model.View" />
        @if (Model.AreaFilter.HasValue)
        {
            <input type="hidden" name="area" value="@((int)Model.AreaFilter.Value)" />
        }
        @* Status dropdown: hidden in Incomplete view (the view fixes the status set).
           Dashboard drill-throughs that pass an explicit ?status=... still work because the
           value is preserved in the page model and submitted as a hidden input. *@
        @if (isIncomplete)
        {
            @if (Model.StatusFilter.HasValue)
            {
                <input type="hidden" name="status" value="@Model.StatusFilter" />
            }
        }
        else
        {
            <select name="status" class="form-select form-select-sm" style="width:auto" onchange="this.form.submit()">
                <option value="">All Status</option>
                @foreach (var s in Enum.GetValues<TaskPilot.Models.Enums.TaskStatus>())
                {
                    <option value="@s" selected="@(Model.StatusFilter == s)">@s</option>
                }
            </select>
        }
        <select name="priority" class="form-select form-select-sm" style="width:auto" onchange="this.form.submit()">
            <option value="">All Priority</option>
            @foreach (var p in Enum.GetValues<TaskPilot.Models.Enums.TaskPriority>())
            {
                <option value="@p" selected="@(Model.PriorityFilter == p)">@p</option>
            }
        </select>
        <select name="taskTypeId" class="form-select form-select-sm" style="width:auto" onchange="this.form.submit()">
            <option value="">All Types</option>
            @foreach (var t in Model.TaskTypes)
            {
                <option value="@t.Id" selected="@(Model.TaskTypeIdFilter == t.Id)">@t.Name</option>
            }
        </select>
        @if (Model.AllTags.Count > 0)
        {
            <div class="dropdown">
                <button class="btn btn-sm btn-outline-secondary dropdown-toggle" type="button" data-bs-toggle="dropdown">
                    Tags @(Model.TagIdFilter?.Count > 0 ? $"({Model.TagIdFilter.Count})" : "")
                </button>
                <div class="dropdown-menu p-2" style="min-width:180px">
                    @foreach (var tag in Model.AllTags)
                    {
                        <div class="form-check">
                            <input class="form-check-input" type="checkbox" name="tagIds" value="@tag.Id"
                                   id="tag-filter-@tag.Id"
                                   @(Model.TagIdFilter != null && Model.TagIdFilter.Contains(tag.Id) ? "checked" : "")
                                   onchange="this.form.submit()" />
                            <label class="form-check-label d-flex align-items-center gap-1" for="tag-filter-@tag.Id">
                                <span style="display:inline-block;width:10px;height:10px;border-radius:50%;background:@tag.Color"></span>
                                @tag.Name
                            </label>
                        </div>
                    }
                </div>
            </div>
        }
        @* Overdue chip — toggle button. Submits the form with overdue=true on, removes the param off. *@
        <button type="submit" name="overdue" value="@(Model.OverdueFilter ? "false" : "true")"
                class="btn btn-sm tp-overdue-chip @(Model.OverdueFilter ? "tp-overdue-chip-on" : "btn-outline-secondary")"
                aria-pressed="@(Model.OverdueFilter ? "true" : "false")"
                title="@(Model.OverdueFilter ? "Click to remove the Overdue filter" : "Filter to overdue tasks only")">
            <i class="bi bi-exclamation-triangle me-1"></i>Overdue
        </button>
    </form>

    <div class="tp-view-toggle btn-group ms-auto" role="group">
        <a href="@Url.Page("/Tasks/Index", FilterRoute(viewOverride: "list"))"
           class="btn btn-sm @(!isBoard && !isIncomplete ? "btn-secondary" : "btn-outline-secondary")" title="List view">
            <i class="bi bi-list-ul"></i>
        </a>
        <a href="@Url.Page("/Tasks/Index", FilterRoute(viewOverride: "board"))"
           class="btn btn-sm @(isBoard ? "btn-secondary" : "btn-outline-secondary")" title="Board view">
            <i class="bi bi-kanban"></i>
        </a>
        <a href="@Url.Page("/Tasks/Index", FilterRoute(viewOverride: "incomplete"))"
           class="btn btn-sm @(isIncomplete ? "btn-secondary" : "btn-outline-secondary")" title="Incomplete only">
            <i class="bi bi-check2-square"></i>
        </a>
    </div>
</div>

<div id="task-container">
    @if (!isBoard)
    {
        <!-- List View -->
        @if (Model.Tasks.Count == 0)
        {
            <div class="tp-card">
                <div class="tp-empty">
                    <div class="tp-empty-icon"><i class="bi bi-clipboard"></i></div>
                    @if (isIncomplete && Model.OverdueFilter)
                    {
                        <div class="tp-empty-title">Nothing overdue. Nice.</div>
                        <div class="tp-empty-text">All your incomplete tasks are still on time.</div>
                    }
                    else if (isIncomplete)
                    {
                        <div class="tp-empty-title">No incomplete tasks match these filters.</div>
                        <div class="tp-empty-text">Try clearing a filter, or check the dashboard for what's left.</div>
                    }
                    else
                    {
                        <div class="tp-empty-title">No tasks found</div>
                        <div class="tp-empty-text">Try changing your filters or create a new task</div>
                    }
                </div>
            </div>
        }
        else
        {
            <div class="tp-card">
                <div class="tp-table-scroll">
                <table class="tp-table">
                    <thead>
                        <tr>
                            <th>Title</th>
                            <th>Area</th>
                            <th>Type</th>
                            <th>Priority</th>
                            <th>Status</th>
                            <th>Due</th>
                            <th>Tags</th>
                            <th></th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var task in Model.Tasks)
                        {
                            <tr>
                                <td>
                                    <a href="/tasks/@task.Id" class="text-decoration-none fw-medium">
                                        @task.Title
                                    </a>
                                </td>
                                <td>@Html.Raw(AreaBadge(task.Area))</td>
                                <td><span class="text-muted small">@(task.TaskTypeName ?? "—")</span></td>
                                <td>@Html.Raw(PriorityBadge(task.Priority))</td>
                                <td>@Html.Raw(StatusBadge(task.Status))</td>
                                <td>
                                    @if (task.TargetDate.HasValue)
                                    {
                                        var isOverdue = task.TargetDate.Value < nowUtc
                                            && task.Status != TaskPilot.Models.Enums.TaskStatus.Completed
                                            && task.Status != TaskPilot.Models.Enums.TaskStatus.Cancelled;
                                        <span class="small text-muted">@task.TargetDate.Value.ToString("MMM d")</span>
                                        @if (isOverdue)
                                        {
                                            <span class="tp-badge tp-badge-overdue ms-1" title="Overdue">Overdue</span>
                                        }
                                    }
                                </td>
                                <td>
                                    @foreach (var tag in task.Tags)
                                    {
                                        <span class="badge" style="background-color:@tag.Color;font-size:11px">@tag.Name</span>
                                    }
                                </td>
                                <td class="text-end">
                                    <a href="/tasks/@task.Id" class="btn btn-sm btn-outline-secondary">
                                        <i class="bi bi-pencil"></i>
                                    </a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
                </div>
            </div>
        }
    }
    else
    {
        <!-- Board / Kanban View -->
        <div class="tp-kanban">
            @foreach (var col in Model.KanbanColumns)
            {
                <div class="tp-kanban-col">
                    <div class="tp-kanban-col-header">
                        @col.Key
                        <span class="tp-kanban-count">@col.Value.Count</span>
                    </div>
                    @foreach (var task in col.Value)
                    {
                        <a href="/tasks/@task.Id" class="text-decoration-none">
                            <div class="tp-task-card">
                                <div class="tp-task-card-title">@task.Title</div>
                                <div class="tp-task-card-meta">
                                    @Html.Raw(PriorityBadge(task.Priority))
                                    @Html.Raw(AreaBadge(task.Area))
                                    @if (task.TaskTypeName != null)
                                    {
                                        <span class="small text-muted">@task.TaskTypeName</span>
                                    }
                                </div>
                                @if (task.Tags.Count > 0)
                                {
                                    <div class="mt-1">
                                        @foreach (var tag in task.Tags)
                                        {
                                            <span class="badge" style="background-color:@tag.Color;font-size:10px">@tag.Name</span>
                                        }
                                    </div>
                                }
                            </div>
                        </a>
                    }
                    @if (col.Value.Count == 0)
                    {
                        <div class="text-center py-3 text-muted small">No tasks</div>
                    }
                </div>
            }
        </div>
    }
</div>

<!-- New Task Modal -->
<div class="modal fade tp-modal" id="taskModal" tabindex="-1">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">New Task</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <form method="post" asp-page-handler="Create">
                <div class="modal-body">
                    <div class="row g-3">
                        <!-- Area segmented control -->
                        <div class="col-12">
                            <label class="form-label">Area</label>
                            <div class="btn-group w-100" role="group">
                                <input type="radio" class="btn-check" name="area" id="areaPersonal" value="0" checked autocomplete="off" />
                                <label class="btn btn-outline-primary" for="areaPersonal">Personal</label>
                                <input type="radio" class="btn-check" name="area" id="areaWork" value="1" autocomplete="off" />
                                <label class="btn btn-outline-primary" for="areaWork">Work</label>
                            </div>
                        </div>
                        <div class="col-12">
                            <label class="form-label">Title *</label>
                            <input type="text" class="form-control" name="Title" required placeholder="Task title" />
                        </div>
                        <div class="col-12">
                            <label class="form-label">Description</label>
                            <textarea class="form-control" name="Description" rows="2" placeholder="Optional description"></textarea>
                        </div>
                        <div class="col-sm-4">
                            <label class="form-label">Type *</label>
                            <select class="form-select" name="taskTypeId" required>
                                <option value="">-- Select Type --</option>
                                @foreach (var t in Model.TaskTypes)
                                {
                                    <option value="@t.Id">@t.Name</option>
                                }
                            </select>
                            <div class="invalid-feedback">Type is required.</div>
                        </div>
                        <div class="col-sm-4">
                            <label class="form-label">Priority *</label>
                            <select class="form-select" name="Priority">
                                @foreach (var p in Enum.GetValues<TaskPilot.Models.Enums.TaskPriority>())
                                {
                                    <option value="@((int)p)" selected="@(p == TaskPilot.Models.Enums.TaskPriority.Medium)">@p</option>
                                }
                            </select>
                        </div>
                        <div class="col-sm-4">
                            <label class="form-label">Status *</label>
                            <select class="form-select" name="Status">
                                @foreach (var s in Enum.GetValues<TaskPilot.Models.Enums.TaskStatus>())
                                {
                                    <option value="@((int)s)">@s</option>
                                }
                            </select>
                        </div>
                        <div class="col-sm-6">
                            <label class="form-label">Target Date</label>
                            <input type="date" class="form-control" name="TargetDate" />
                        </div>
                        <div class="col-sm-6">
                            <label class="form-label">Timeline</label>
                            <select class="form-select" name="TargetDateType">
                                @foreach (var t in Enum.GetValues<TaskPilot.Models.Enums.TargetDateType>())
                                {
                                    <option value="@((int)t)">@t</option>
                                }
                            </select>
                        </div>
                        <div class="col-12">
                            <label class="form-label">Tags</label>
                            <div id="modal-tags-list" class="d-flex flex-wrap gap-2 mb-1">
                                @if (Model.AllTags.Count == 0)
                                {
                                    <p class="text-muted small mb-2">No tags yet — create one below.</p>
                                }
                                @foreach (var tag in Model.AllTags)
                                {
                                    <div class="form-check form-check-inline">
                                        <input class="form-check-input" type="checkbox" name="TagIds" value="@tag.Id" id="modal-tag-@tag.Id" />
                                        <label class="form-check-label" for="modal-tag-@tag.Id">
                                            <span style="display:inline-block;width:10px;height:10px;border-radius:50%;background:@tag.Color;margin-right:3px"></span>
                                            @tag.Name
                                        </label>
                                    </div>
                                }
                            </div>
                            <div class="tp-tag-inline-create mt-2">
                                <div class="d-flex align-items-center gap-2 flex-wrap">
                                    <input type="text" id="newTagName" class="form-control form-control-sm" style="max-width:160px" placeholder="New tag name..." maxlength="50" />
                                    <input type="hidden" id="newTagColor" value="#7C3AED" />
                                    <div class="d-flex gap-1" id="newTagColorSwatches">
                                        <span class="tp-color-swatch selected" data-color="#7C3AED" style="background:#7C3AED" title="Purple" onclick="selectTagColor(this)"></span>
                                        <span class="tp-color-swatch" data-color="#2563EB" style="background:#2563EB" title="Blue" onclick="selectTagColor(this)"></span>
                                        <span class="tp-color-swatch" data-color="#0D9488" style="background:#0D9488" title="Teal" onclick="selectTagColor(this)"></span>
                                        <span class="tp-color-swatch" data-color="#16A34A" style="background:#16A34A" title="Green" onclick="selectTagColor(this)"></span>
                                        <span class="tp-color-swatch" data-color="#D97706" style="background:#D97706" title="Amber" onclick="selectTagColor(this)"></span>
                                        <span class="tp-color-swatch" data-color="#EA580C" style="background:#EA580C" title="Orange" onclick="selectTagColor(this)"></span>
                                        <span class="tp-color-swatch" data-color="#E11D48" style="background:#E11D48" title="Red" onclick="selectTagColor(this)"></span>
                                        <span class="tp-color-swatch" data-color="#64748B" style="background:#64748B" title="Slate" onclick="selectTagColor(this)"></span>
                                    </div>
                                    <button type="button" class="btn btn-outline-secondary btn-sm" onclick="createTagInline(this)">+ Add</button>
                                </div>
                                <div id="tag-inline-error" class="text-danger small mt-1" style="display:none"></div>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-primary">Save Task</button>
                </div>
            </form>
        </div>
    </div>
</div>

@functions {
    string StatusBadge(TaskPilot.Models.Enums.TaskStatus s) => s switch {
        TaskPilot.Models.Enums.TaskStatus.NotStarted => "<span class='tp-badge tp-badge-not-started'>Not Started</span>",
        TaskPilot.Models.Enums.TaskStatus.InProgress  => "<span class='tp-badge tp-badge-in-progress'>In Progress</span>",
        TaskPilot.Models.Enums.TaskStatus.Blocked      => "<span class='tp-badge tp-badge-blocked'>Blocked</span>",
        TaskPilot.Models.Enums.TaskStatus.Completed    => "<span class='tp-badge tp-badge-completed'>Completed</span>",
        TaskPilot.Models.Enums.TaskStatus.Cancelled    => "<span class='tp-badge tp-badge-cancelled'>Cancelled</span>",
        _ => s.ToString()
    };
    string PriorityBadge(TaskPilot.Models.Enums.TaskPriority p) => p switch {
        TaskPilot.Models.Enums.TaskPriority.Critical => "<span class='tp-badge tp-badge-critical'>Critical</span>",
        TaskPilot.Models.Enums.TaskPriority.High     => "<span class='tp-badge tp-badge-high'>High</span>",
        TaskPilot.Models.Enums.TaskPriority.Medium   => "<span class='tp-badge tp-badge-medium'>Medium</span>",
        TaskPilot.Models.Enums.TaskPriority.Low      => "<span class='tp-badge tp-badge-low'>Low</span>",
        _ => p.ToString()
    };
    string AreaBadge(TaskPilot.Models.Enums.Area a) => a switch {
        TaskPilot.Models.Enums.Area.Work     => "<span class='badge bg-info text-dark'>Work</span>",
        TaskPilot.Models.Enums.Area.Personal => "<span class='badge bg-secondary'>Personal</span>",
        _ => a.ToString()
    };
}

@section Scripts {
<script>
// Open new task modal if ?action=new
if (new URLSearchParams(location.search).get('action') === 'new') {
    new bootstrap.Modal(document.getElementById('taskModal')).show();
    history.replaceState({}, '', '/tasks');
}

function selectTagColor(swatch) {
    document.querySelectorAll('#newTagColorSwatches .tp-color-swatch').forEach(s => s.classList.remove('selected'));
    swatch.classList.add('selected');
    document.getElementById('newTagColor').value = swatch.dataset.color;
}

async function createTagInline(btn) {
    const nameInput = document.getElementById('newTagName');
    const colorSelect = document.getElementById('newTagColor');
    const errorDiv = document.getElementById('tag-inline-error');
    const name = nameInput.value.trim();
    const color = colorSelect.value;

    errorDiv.style.display = 'none';
    errorDiv.textContent = '';

    if (!name) {
        errorDiv.textContent = 'Tag name is required.';
        errorDiv.style.display = 'block';
        return;
    }

    const token = document.querySelector('input[name="__RequestVerificationToken"]')?.value;
    btn.disabled = true;

    try {
        const response = await fetch('/api/v1/tags', {
            method: 'POST',
            headers: {
                'Content-Type': 'application/json',
                ...(token ? { 'RequestVerificationToken': token } : {})
            },
            body: JSON.stringify({ name, color })
        });

        if (!response.ok) {
            const data = await response.json().catch(() => ({}));
            errorDiv.textContent = data?.error?.message || `Error: ${response.status}`;
            errorDiv.style.display = 'block';
            return;
        }

        const data = await response.json();
        const tag = data.data ?? data;
        const tagId = tag.id;
        const tagName = tag.name;
        const tagColor = tag.color;

        const tagList = document.getElementById('modal-tags-list');
        // Remove "no tags yet" message if present
        const noTagsMsg = tagList.querySelector('p.text-muted');
        if (noTagsMsg) noTagsMsg.remove();

        const div = document.createElement('div');
        div.className = 'form-check form-check-inline';
        div.innerHTML = `
            <input class="form-check-input" type="checkbox" name="TagIds" value="${tagId}" id="modal-tag-${tagId}" checked />
            <label class="form-check-label" for="modal-tag-${tagId}">
                <span style="display:inline-block;width:10px;height:10px;border-radius:50%;background:${tagColor};margin-right:3px"></span>
                ${tagName}
            </label>`;
        tagList.appendChild(div);

        nameInput.value = '';
    } catch (err) {
        errorDiv.textContent = 'Failed to create tag. Please try again.';
        errorDiv.style.display = 'block';
    } finally {
        btn.disabled = false;
    }
}
</script>
}
