@page "/integrations"
@model TaskPilot.Pages.Integrations.IntegrationsIndexModel
@{
    ViewData["Title"] = "Integrations";
}

<div class="tp-page-header">
    <h1 class="tp-page-title"><i class="bi bi-plug me-2"></i>Integrations</h1>
    <p class="text-muted mt-1">Connect LLMs and automation tools to TaskPilot using your API keys.</p>
</div>

<!-- Section A: Quick Start -->
<div class="tp-settings-section" id="quick-start">
    <h2 class="tp-settings-section-title">
        <i class="bi bi-lightning-charge"></i> Quick Start
    </h2>
    <div class="tp-settings-body">
        <p class="text-muted small mb-4">Three steps to connect any LLM or automation tool to TaskPilot.</p>

        <div class="d-flex flex-column gap-3">
            <div class="d-flex gap-3 align-items-start">
                <span class="tp-step-number">1</span>
                <div>
                    <div class="fw-semibold">Create an API key</div>
                    <div class="text-muted small mt-1">Go to <a href="/settings#api-keys">Settings → API Keys</a> and generate a key. Copy it immediately — it is only shown once.</div>
                </div>
            </div>
            <div class="d-flex gap-3 align-items-start">
                <span class="tp-step-number">2</span>
                <div>
                    <div class="fw-semibold">Note your base URL</div>
                    <div class="text-muted small mt-1">
                        Local development: <code>http://localhost:5125</code><br />
                        Production: your deployed app URL
                    </div>
                </div>
            </div>
            <div class="d-flex gap-3 align-items-start">
                <span class="tp-step-number">3</span>
                <div>
                    <div class="fw-semibold">Include your key on every request</div>
                    <div class="text-muted small mt-1">Add the <code>X-Api-Key</code> header with your key value.</div>
                </div>
            </div>
        </div>

        <div class="mt-4">
            <div class="d-flex justify-content-between align-items-center mb-1">
                <span class="small fw-semibold text-muted">EXAMPLE — curl</span>
                <button class="btn btn-sm btn-outline-secondary tp-copy-btn" data-target="curl-example">
                    <i class="bi bi-clipboard me-1"></i>Copy
                </button>
            </div>
            <pre class="tp-code-block" id="curl-example">curl -H "X-Api-Key: tp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx" \
     https://yourapp/api/v1/tasks</pre>
        </div>
    </div>
</div>

<!-- Section B: REST API Reference -->
<div class="tp-settings-section" id="rest-api">
    <h2 class="tp-settings-section-title">
        <i class="bi bi-braces"></i> REST API Reference
    </h2>
    <div class="tp-settings-body">
        <p class="text-muted small mb-3">All endpoints are under <code>/api/v1/</code> and require the <code>X-Api-Key</code> header.</p>

        <div class="table-responsive">
            <table class="table table-sm table-hover small">
                <thead class="table-light">
                    <tr>
                        <th style="width:90px">Method</th>
                        <th style="width:260px">Path</th>
                        <th>Description</th>
                    </tr>
                </thead>
                <tbody>
                    <tr><td><span class="badge bg-primary">GET</span></td><td><code>/api/v1/tasks</code></td><td>List tasks (supports filtering, pagination)</td></tr>
                    <tr><td><span class="badge bg-primary">GET</span></td><td><code>/api/v1/tasks/{id}</code></td><td>Get a single task by ID</td></tr>
                    <tr><td><span class="badge bg-success">POST</span></td><td><code>/api/v1/tasks</code></td><td>Create a new task</td></tr>
                    <tr><td><span class="badge bg-warning text-dark">PUT</span></td><td><code>/api/v1/tasks/{id}</code></td><td>Update a task</td></tr>
                    <tr><td><span class="badge bg-info text-dark">PATCH</span></td><td><code>/api/v1/tasks/{id}</code></td><td>Partially update a task (e.g. status only)</td></tr>
                    <tr><td><span class="badge bg-danger">DELETE</span></td><td><code>/api/v1/tasks/{id}</code></td><td>Soft-delete a task</td></tr>
                    <tr><td><span class="badge bg-primary">GET</span></td><td><code>/api/v1/tags</code></td><td>List all tags</td></tr>
                    <tr><td><span class="badge bg-success">POST</span></td><td><code>/api/v1/tags</code></td><td>Create a tag</td></tr>
                    <tr><td><span class="badge bg-primary">GET</span></td><td><code>/api/v1/task-types</code></td><td>List task types (Task, Goal, Habit…)</td></tr>
                    <tr><td><span class="badge bg-primary">GET</span></td><td><code>/api/v1/tasks/stats</code></td><td>Get task statistics summary</td></tr>
                    <tr><td><span class="badge bg-primary">GET</span></td><td><code>/api/v1/activity-logs</code></td><td>Get activity log entries</td></tr>
                </tbody>
            </table>
        </div>

        @if (Model.IsDevelopment)
        {
            <a href="/swagger" target="_blank" class="btn btn-sm btn-outline-primary mt-2">
                <i class="bi bi-box-arrow-up-right me-1"></i>Open API Docs (Swagger)
            </a>
        }
        else
        {
            <p class="text-muted small mt-2">
                <i class="bi bi-info-circle me-1"></i>Full interactive API docs are available in development mode via <code>/swagger</code>.
            </p>
        }
    </div>
</div>

<!-- Section C: Claude (Anthropic) -->
<div class="tp-settings-section" id="claude">
    <h2 class="tp-settings-section-title">
        <i class="bi bi-robot"></i> Claude (Anthropic)
    </h2>
    <div class="tp-settings-body">
        <p class="text-muted small mb-3">
            Use <a href="https://docs.anthropic.com/en/docs/build-with-claude/tool-use" target="_blank">Claude tool use</a>
            to let Claude read and manage your tasks. Pass these tool definitions in your API call's <code>tools</code> array,
            then handle <code>tool_use</code> blocks by calling TaskPilot's REST API with your API key.
        </p>

        <div class="mt-3">
            <div class="d-flex justify-content-between align-items-center mb-1">
                <span class="small fw-semibold text-muted">TOOL DEFINITION — list_tasks</span>
                <button class="btn btn-sm btn-outline-secondary tp-copy-btn" data-target="claude-list-tasks">
                    <i class="bi bi-clipboard me-1"></i>Copy
                </button>
            </div>
            <pre class="tp-code-block" id="claude-list-tasks">{
  "name": "list_tasks",
  "description": "List TaskPilot tasks for the authenticated user",
  "input_schema": {
    "type": "object",
    "properties": {
      "status":   { "type": "string", "enum": ["NotStarted","InProgress","Completed","Blocked","Cancelled"] },
      "priority": { "type": "string", "enum": ["Low","Medium","High","Critical"] },
      "area":     { "type": "string", "enum": ["Personal","Work"] },
      "search":   { "type": "string", "description": "Search by title keyword" },
      "page":     { "type": "integer", "default": 1 },
      "pageSize": { "type": "integer", "default": 20 }
    }
  }
}</pre>
        </div>

        <div class="mt-3">
            <div class="d-flex justify-content-between align-items-center mb-1">
                <span class="small fw-semibold text-muted">TOOL DEFINITION — create_task</span>
                <button class="btn btn-sm btn-outline-secondary tp-copy-btn" data-target="claude-create-task">
                    <i class="bi bi-clipboard me-1"></i>Copy
                </button>
            </div>
            <pre class="tp-code-block" id="claude-create-task">{
  "name": "create_task",
  "description": "Create a new task in TaskPilot",
  "input_schema": {
    "type": "object",
    "required": ["title", "taskTypeId", "priority", "status", "targetDateType"],
    "properties": {
      "title":          { "type": "string" },
      "description":    { "type": "string" },
      "taskTypeId":     { "type": "integer", "description": "1=Task 2=Goal 3=Habit 4=Meeting 5=Note 6=Event" },
      "area":           { "type": "integer", "description": "0=Personal 1=Work" },
      "priority":       { "type": "integer", "description": "0=Low 1=Medium 2=High 3=Critical" },
      "status":         { "type": "integer", "description": "0=NotStarted 1=InProgress 2=Completed 3=Blocked 4=Cancelled" },
      "targetDateType": { "type": "integer", "description": "0=None 1=ThisWeek 2=NextWeek 3=SpecificDay" },
      "isRecurring":    { "type": "boolean", "default": false }
    }
  }
}</pre>
        </div>

        <div class="mt-3 p-3 rounded" style="background:#f8f9fa;border:1px solid #e9ecef">
            <div class="small fw-semibold mb-1">How to handle tool calls</div>
            <ol class="small text-muted mb-0 ps-3">
                <li>Send a message to Claude with the tool definitions above in the <code>tools</code> array.</li>
                <li>When Claude returns a <code>tool_use</code> block, call the corresponding TaskPilot endpoint with your <code>X-Api-Key</code> header.</li>
                <li>Return the result as a <code>tool_result</code> message and continue the conversation.</li>
            </ol>
        </div>
    </div>
</div>

<!-- Section D: OpenAI / GPT -->
<div class="tp-settings-section" id="openai">
    <h2 class="tp-settings-section-title">
        <i class="bi bi-stars"></i> OpenAI / GPT
    </h2>
    <div class="tp-settings-body">
        <p class="text-muted small mb-3">
            Use <a href="https://platform.openai.com/docs/guides/function-calling" target="_blank">OpenAI function calling</a>
            to connect GPT models to TaskPilot. Add these function definitions to your API call's <code>tools</code> array.
        </p>

        <div class="mt-3">
            <div class="d-flex justify-content-between align-items-center mb-1">
                <span class="small fw-semibold text-muted">FUNCTION DEFINITION — list_tasks</span>
                <button class="btn btn-sm btn-outline-secondary tp-copy-btn" data-target="openai-list-tasks">
                    <i class="bi bi-clipboard me-1"></i>Copy
                </button>
            </div>
            <pre class="tp-code-block" id="openai-list-tasks">{
  "type": "function",
  "function": {
    "name": "list_tasks",
    "description": "List TaskPilot tasks for the authenticated user",
    "parameters": {
      "type": "object",
      "properties": {
        "status":   { "type": "string", "enum": ["NotStarted","InProgress","Completed","Blocked","Cancelled"] },
        "priority": { "type": "string", "enum": ["Low","Medium","High","Critical"] },
        "area":     { "type": "string", "enum": ["Personal","Work"] },
        "search":   { "type": "string" },
        "page":     { "type": "integer" },
        "pageSize": { "type": "integer" }
      }
    }
  }
}</pre>
        </div>

        <div class="mt-3">
            <div class="d-flex justify-content-between align-items-center mb-1">
                <span class="small fw-semibold text-muted">FUNCTION DEFINITION — create_task</span>
                <button class="btn btn-sm btn-outline-secondary tp-copy-btn" data-target="openai-create-task">
                    <i class="bi bi-clipboard me-1"></i>Copy
                </button>
            </div>
            <pre class="tp-code-block" id="openai-create-task">{
  "type": "function",
  "function": {
    "name": "create_task",
    "description": "Create a new task in TaskPilot",
    "parameters": {
      "type": "object",
      "required": ["title", "taskTypeId", "priority", "status", "targetDateType"],
      "properties": {
        "title":          { "type": "string" },
        "description":    { "type": "string" },
        "taskTypeId":     { "type": "integer", "description": "1=Task 2=Goal 3=Habit 4=Meeting 5=Note 6=Event" },
        "area":           { "type": "integer", "description": "0=Personal 1=Work" },
        "priority":       { "type": "integer", "description": "0=Low 1=Medium 2=High 3=Critical" },
        "status":         { "type": "integer", "description": "0=NotStarted 1=InProgress 2=Completed 3=Blocked 4=Cancelled" },
        "targetDateType": { "type": "integer", "description": "0=None 1=ThisWeek 2=NextWeek 3=SpecificDay" },
        "isRecurring":    { "type": "boolean" }
      }
    }
  }
}</pre>
        </div>
    </div>
</div>

<!-- Section E: MCP -->
<div class="tp-settings-section" id="mcp">
    <h2 class="tp-settings-section-title">
        <i class="bi bi-diagram-3"></i> MCP (Model Context Protocol)
        <span class="badge bg-success ms-2" style="font-size:11px;vertical-align:middle">Live</span>
    </h2>
    <div class="tp-settings-body">
        <p class="text-muted small mb-3">
            Connect Claude Desktop, Claude.ai Projects, or any MCP-compatible agent directly to TaskPilot.
            The MCP server exposes 9 tools — read and write tasks, tags, and stats without writing any integration code.
        </p>

        <!-- Quick Connect Steps -->
        <div class="mb-4">
            <div class="d-flex align-items-start gap-3 mb-3">
                <span class="tp-step-number">1</span>
                <div>
                    <div class="fw-semibold">Create an API key</div>
                    <div class="text-muted small">Go to <a href="/settings#api-keys">Settings → API Keys</a>, generate a key and copy it — it's shown once.</div>
                </div>
            </div>
            <div class="d-flex align-items-start gap-3 mb-3">
                <span class="tp-step-number">2</span>
                <div>
                    <div class="fw-semibold">Note your MCP endpoint</div>
                    <div class="text-muted small">The endpoint uses SSE (HTTP) transport — compatible with Claude Desktop 0.10+ and Claude.ai Projects.</div>
                    <code class="d-block mt-1 px-2 py-1 rounded" style="background:#f1f3f5;font-size:13px">https://taskpilot.azurewebsites.net/mcp</code>
                </div>
            </div>
            <div class="d-flex align-items-start gap-3">
                <span class="tp-step-number">3</span>
                <div>
                    <div class="fw-semibold">Add TaskPilot to your MCP client</div>
                    <div class="text-muted small mb-2">Use the config block below — paste it into <code>claude_desktop_config.json</code> or your client's MCP server settings.</div>
                </div>
            </div>
        </div>

        <!-- Claude Desktop Config -->
        <div class="mb-4">
            <div class="d-flex justify-content-between align-items-center mb-1">
                <span class="fw-semibold small">Claude Desktop — <code>claude_desktop_config.json</code></span>
                <button class="btn btn-sm btn-outline-secondary tp-copy-btn" data-target="mcp-claude-config">
                    <i class="bi bi-clipboard me-1"></i>Copy
                </button>
            </div>
            <pre class="tp-code-block" id="mcp-claude-config">{
  "mcpServers": {
    "taskpilot": {
      "type": "sse",
      "url": "https://taskpilot.azurewebsites.net/mcp",
      "headers": {
        "X-Api-Key": "YOUR_API_KEY_HERE"
      }
    }
  }
}</pre>
        </div>

        <!-- Available Tools Table -->
        <div class="mb-3">
            <div class="fw-semibold small mb-2">Available tools (9)</div>
            <div class="table-responsive">
            <table class="table table-sm table-bordered mb-0" style="font-size:13px">
                <thead class="table-light">
                    <tr><th>Tool</th><th>Description</th></tr>
                </thead>
                <tbody>
                    <tr><td><code>list_tasks</code></td><td>List tasks with optional filters (status, area, priority, search)</td></tr>
                    <tr><td><code>get_task</code></td><td>Get a single task by GUID</td></tr>
                    <tr><td><code>create_task</code></td><td>Create a new task</td></tr>
                    <tr><td><code>update_task</code></td><td>Partially update a task (any field)</td></tr>
                    <tr><td><code>complete_task</code></td><td>Mark a task complete with optional result analysis</td></tr>
                    <tr><td><code>delete_task</code></td><td>Soft-delete a task (recoverable in web UI)</td></tr>
                    <tr><td><code>get_stats</code></td><td>Get aggregated stats (active, overdue, completed today…)</td></tr>
                    <tr><td><code>list_tags</code></td><td>List all tags</td></tr>
                    <tr><td><code>list_task_types</code></td><td>List task types (Task, Goal, Habit, Meeting, Note, Event)</td></tr>
                </tbody>
            </table>
            </div>
        </div>

        <div class="alert alert-info py-2 px-3 small mb-0" style="font-size:12px">
            <i class="bi bi-info-circle me-1"></i>
            The MCP server uses <strong>SSE (HTTP) transport</strong>, not stdio. Authentication uses the same <code>X-Api-Key</code> header as the REST API.
        </div>
    </div>
</div>

@section Scripts {
<script>
document.querySelectorAll('.tp-copy-btn').forEach(function(btn) {
    btn.addEventListener('click', function() {
        var targetId = this.getAttribute('data-target');
        var text = document.getElementById(targetId)?.textContent ?? '';
        navigator.clipboard.writeText(text.trim()).then(() => {
            var original = this.innerHTML;
            this.innerHTML = '<i class="bi bi-check-lg me-1"></i>Copied!';
            this.classList.replace('btn-outline-secondary', 'btn-outline-success');
            var self = this;
            setTimeout(function() {
                self.innerHTML = original;
                self.classList.replace('btn-outline-success', 'btn-outline-secondary');
            }, 2000);
        });
    });
});
</script>
}
