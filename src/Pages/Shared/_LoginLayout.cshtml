<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] – TaskPilot</title>
    <link href="/lib/bootstrap/css/bootstrap.min.css" rel="stylesheet" />
    <link href="/lib/bootstrap-icons/font/bootstrap-icons.css" rel="stylesheet" />
    <link rel="stylesheet" href="/css/app.css" />
</head>
<body class="tp-auth-body">
    <div class="tp-auth-container">
        <div class="tp-auth-brand">
            <i class="bi bi-check2-square tp-auth-logo"></i>
            <h1 class="tp-auth-title">TaskPilot</h1>
            <p class="tp-auth-subtitle">Your personal command center</p>
        </div>
        <div class="tp-auth-card card shadow-sm">
            <div class="card-body p-4">
                @RenderBody()
            </div>
        </div>
    </div>
    <script src="/lib/bootstrap/js/bootstrap.bundle.min.js"></script>
</body>
</html>
