@inject TaskPilot.Services.Interfaces.IChangelogService _changelogService
@inject IWebHostEnvironment _env
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] – TaskPilot</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet" />
    <link rel="stylesheet" href="/css/app.css" />
</head>
<body class="tp-app">

<nav class="tp-sidebar d-flex flex-column">
    <div class="tp-sidebar-brand">
        <span class="tp-logo">
            <i class="bi bi-check2-square"></i>
        </span>
        <span class="tp-brand-text">TaskPilot</span>
    </div>

    <ul class="tp-nav flex-grow-1">
        <li class="tp-nav-item">
            <a class="tp-nav-link @(ViewContext.RouteData.Values["page"]?.ToString() == "/Index" ? "active" : "")"
               href="/">
                <i class="bi bi-speedometer2"></i>
                <span>Dashboard</span>
            </a>
        </li>
        <li class="tp-nav-item">
            <a class="tp-nav-link @(ViewContext.RouteData.Values["page"]?.ToString()?.StartsWith("/Tasks") == true ? "active" : "")"
               href="/tasks">
                <i class="bi bi-list-task"></i>
                <span>Tasks</span>
            </a>
        </li>
        <li class="tp-nav-item">
            <a class="tp-nav-link @(ViewContext.RouteData.Values["page"]?.ToString()?.StartsWith("/Audit") == true ? "active" : "")"
               href="/audit">
                <i class="bi bi-shield-check"></i>
                <span>Audit</span>
            </a>
        </li>
        <li class="tp-nav-item">
            <a class="tp-nav-link @(ViewContext.RouteData.Values["page"]?.ToString()?.StartsWith("/Settings") == true ? "active" : "")"
               href="/settings">
                <i class="bi bi-gear"></i>
                <span>Settings</span>
            </a>
        </li>
        <li class="tp-nav-item">
            <a class="tp-nav-link @(ViewContext.RouteData.Values["page"]?.ToString()?.StartsWith("/Integrations") == true ? "active" : "")"
               href="/integrations">
                <i class="bi bi-plug"></i>
                <span>Integrations</span>
            </a>
        </li>
    </ul>

    @if (_env.IsDevelopment())
    {
        <div class="tp-swagger-nav">
            <a class="tp-swagger-nav-link" href="/swagger" target="_blank">
                <i class="bi bi-code-slash"></i>
                <span>API Docs</span>
                <i class="bi bi-box-arrow-up-right ms-auto" style="font-size:10px;opacity:.6"></i>
            </a>
        </div>
    }

    <div class="tp-changelog-nav">
        <a class="tp-changelog-nav-link @(ViewContext.RouteData.Values["page"]?.ToString()?.StartsWith("/Changelog") == true ? "active" : "")"
           href="/changelog">
            <i class="bi bi-journal-text"></i>
            <span>What's new</span>
            @{
                var _latest = _changelogService.GetLatest();
                if (_latest is not null)
                {
                    <span class="tp-version-pill">v@(_latest.Version)</span>
                }
            }
        </a>
    </div>

    <div class="tp-sidebar-footer">
        <span class="tp-user-email">@User.Identity?.Name</span>
        <form method="post" action="/auth/logout" class="d-inline">
            @Html.AntiForgeryToken()
            <button type="submit" class="tp-logout-btn" title="Logout">
                <i class="bi bi-box-arrow-right"></i>
                <span>Logout</span>
            </button>
        </form>
    </div>
</nav>

<main class="tp-main">
    <div class="tp-content">
        @RenderBody()
    </div>
</main>

@if (TempData["Toast"] != null)
{
    <div class="tp-toast-container position-fixed bottom-0 end-0 p-3" style="z-index:9999">
        <div class="toast show align-items-center text-bg-success border-0" role="alert">
            <div class="d-flex">
                <div class="toast-body">@TempData["Toast"]</div>
                <button type="button" class="btn-close btn-close-white me-2 m-auto" data-bs-dismiss="toast"></button>
            </div>
        </div>
    </div>
}
@if (TempData["Error"] != null)
{
    <div class="tp-toast-container position-fixed bottom-0 end-0 p-3" style="z-index:9999">
        <div class="toast show align-items-center text-bg-danger border-0" role="alert">
            <div class="d-flex">
                <div class="toast-body">@TempData["Error"]</div>
                <button type="button" class="btn-close btn-close-white me-2 m-auto" data-bs-dismiss="toast"></button>
            </div>
        </div>
    </div>
}

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/htmx.org@2.0.4/dist/htmx.min.js"></script>
@await RenderSectionAsync("Scripts", required: false)
</body>
</html>
