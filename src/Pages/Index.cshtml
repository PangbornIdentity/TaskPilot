@page "/"
@model TaskPilot.Pages.IndexModel
@{
    ViewData["Title"] = "Dashboard";
}

<div class="tp-page-header">
    <div>
        <h1 class="tp-page-title">Dashboard</h1>
        <p class="tp-page-subtitle">@DateTime.Now.ToString("dddd, MMMM d")</p>
    </div>
    <a href="/tasks?action=new" class="btn btn-primary">
        <i class="bi bi-plus-lg me-1"></i> New Task
    </a>
</div>

<!-- Quick add -->
<form method="post" asp-page-handler="QuickAdd" class="tp-quick-add mb-4">
    <input type="text" name="title" placeholder="Add a task... (press Enter)" class="form-control" autocomplete="off" />
    <button type="submit" class="btn btn-primary px-4">Add</button>
</form>

<!-- Summary cards -->
<div class="tp-stats-grid">
    <div class="tp-stat-card accent">
        <div class="tp-stat-label">Total Active</div>
        <div class="tp-stat-value">@Model.Stats?.TotalActive</div>
    </div>
    <div class="tp-stat-card success">
        <div class="tp-stat-label">Completed Today</div>
        <div class="tp-stat-value">@Model.Stats?.CompletedToday</div>
    </div>
    <a class="tp-stat-card danger tp-stat-card-link"
       href="/tasks?view=incomplete&overdue=true"
       aria-label="Overdue tasks: @Model.Stats?.Overdue. Open the incomplete view filtered to overdue.">
        <div class="tp-stat-label">Overdue</div>
        <div class="tp-stat-value">@Model.Stats?.Overdue</div>
    </a>
    <div class="tp-stat-card warning">
        <div class="tp-stat-label">In Progress</div>
        <div class="tp-stat-value">@Model.Stats?.InProgress</div>
    </div>
    <div class="tp-stat-card">
        <div class="tp-stat-label">Blocked</div>
        <div class="tp-stat-value">@Model.Stats?.Blocked</div>
    </div>
</div>

<!-- Incomplete by Status -->
@{
    var incomplete = Model.Stats?.IncompleteByStatus;
    var incompleteTotal = incomplete?.Total ?? 0;
}
<div class="tp-card tp-incomplete-card mb-3">
    <div class="tp-card-header d-flex justify-content-between align-items-center">
        <span>Incomplete by Status</span>
        <span class="tp-incomplete-total" aria-live="polite">Total: @incompleteTotal</span>
    </div>
    @if (incompleteTotal == 0)
    {
        <div class="tp-card-body text-center text-muted py-3">
            Nothing incomplete &mdash; you&rsquo;re caught up.
        </div>
    }
    else
    {
        <div class="tp-card-body p-0">
            <div class="tp-incomplete-grid">
                <a class="tp-incomplete-tile tp-incomplete-tile-not-started"
                   href="/tasks?view=incomplete&status=NotStarted"
                   aria-label="Open the incomplete view filtered to Not Started: @(incomplete?.NotStarted ?? 0) task(s)">
                    <div class="tp-incomplete-tile-label">Not Started</div>
                    <div class="tp-incomplete-tile-count" aria-live="polite">@(incomplete?.NotStarted ?? 0)</div>
                    <div class="tp-incomplete-tile-arrow"><i class="bi bi-arrow-right"></i></div>
                </a>
                <a class="tp-incomplete-tile tp-incomplete-tile-in-progress"
                   href="/tasks?view=incomplete&status=InProgress"
                   aria-label="Open the incomplete view filtered to In Progress: @(incomplete?.InProgress ?? 0) task(s)">
                    <div class="tp-incomplete-tile-label">In Progress</div>
                    <div class="tp-incomplete-tile-count" aria-live="polite">@(incomplete?.InProgress ?? 0)</div>
                    <div class="tp-incomplete-tile-arrow"><i class="bi bi-arrow-right"></i></div>
                </a>
                <a class="tp-incomplete-tile tp-incomplete-tile-blocked"
                   href="/tasks?view=incomplete&status=Blocked"
                   aria-label="Open the incomplete view filtered to Blocked: @(incomplete?.Blocked ?? 0) task(s)">
                    <div class="tp-incomplete-tile-label">Blocked</div>
                    <div class="tp-incomplete-tile-count" aria-live="polite">@(incomplete?.Blocked ?? 0)</div>
                    <div class="tp-incomplete-tile-arrow"><i class="bi bi-arrow-right"></i></div>
                </a>
            </div>
        </div>
    }
</div>

<!-- Area split stat block -->
<div class="row g-3 mb-3">
    <div class="col-md-6">
        <div class="tp-card h-100">
            <div class="tp-card-header">Completed by Area</div>
            <div class="tp-card-body d-flex justify-content-around align-items-center py-3">
                <div class="text-center">
                    <div class="tp-stat-value" style="font-size:2rem">@Model.Stats?.CompletionsByArea.Personal</div>
                    <div class="text-muted small"><span class="badge bg-secondary">Personal</span></div>
                </div>
                <div class="text-center">
                    <div class="tp-stat-value" style="font-size:2rem">@Model.Stats?.CompletionsByArea.Work</div>
                    <div class="text-muted small"><span class="badge bg-info text-dark">Work</span></div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-6">
        <div class="tp-card h-100">
            <div class="tp-card-header">Top Tags</div>
            <div class="tp-card-body">
                @if (Model.Stats?.TopTags?.Count > 0)
                {
                    <div id="chart-top-tags" style="min-height:150px"></div>
                }
                else
                {
                    <div class="tp-empty py-3">
                        <div class="tp-empty-text">No tags yet</div>
                    </div>
                }
            </div>
        </div>
    </div>
</div>

<!-- Charts -->
<div class="tp-charts-grid">
    <div class="tp-card">
        <div class="tp-card-header">Completed per Week</div>
        <div class="tp-card-body">
            <div id="chart-weekly" style="min-height:200px"></div>
        </div>
    </div>
    <div class="tp-card">
        <div class="tp-card-header">By Priority</div>
        <div class="tp-card-body">
            <div id="chart-priority" style="min-height:200px"></div>
        </div>
    </div>
</div>

<!-- Type breakdown chart -->
<div class="tp-card mb-3">
    <div class="tp-card-header">Tasks by Type</div>
    <div class="tp-card-body">
        <div id="chart-type" style="min-height:200px"></div>
    </div>
</div>

<!-- Recent tasks -->
<div class="tp-card">
    <div class="tp-card-header">
        Recent Tasks
        <a href="/tasks" class="btn btn-sm btn-outline-primary">View all</a>
    </div>
    @if (Model.RecentTasks.Count == 0)
    {
        <div class="tp-empty">
            <div class="tp-empty-icon"><i class="bi bi-clipboard"></i></div>
            <div class="tp-empty-title">No tasks yet</div>
            <div class="tp-empty-text">Create your first task above</div>
        </div>
    }
    else
    {
        <div class="tp-table-scroll">
        <table class="tp-table">
            <thead>
                <tr>
                    <th>Title</th>
                    <th>Area</th>
                    <th>Priority</th>
                    <th>Status</th>
                    <th>Type</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var task in Model.RecentTasks)
                {
                    <tr>
                        <td><a href="/tasks/@task.Id" class="text-decoration-none fw-medium">@task.Title</a></td>
                        <td>
                            @if (task.Area == TaskPilot.Models.Enums.Area.Work)
                            {
                                <span class="badge bg-info text-dark">Work</span>
                            }
                            else
                            {
                                <span class="badge bg-secondary">Personal</span>
                            }
                        </td>
                        <td>@Html.Raw(PriorityBadge(task.Priority))</td>
                        <td>@Html.Raw(StatusBadge(task.Status))</td>
                        <td><span class="text-muted">@(task.TaskTypeName ?? "—")</span></td>
                    </tr>
                }
            </tbody>
        </table>
        </div>
    }
</div>

@functions {
    string StatusBadge(TaskPilot.Models.Enums.TaskStatus s) => s switch {
        TaskPilot.Models.Enums.TaskStatus.NotStarted => "<span class='tp-badge tp-badge-not-started'>Not Started</span>",
        TaskPilot.Models.Enums.TaskStatus.InProgress  => "<span class='tp-badge tp-badge-in-progress'>In Progress</span>",
        TaskPilot.Models.Enums.TaskStatus.Blocked      => "<span class='tp-badge tp-badge-blocked'>Blocked</span>",
        TaskPilot.Models.Enums.TaskStatus.Completed    => "<span class='tp-badge tp-badge-completed'>Completed</span>",
        TaskPilot.Models.Enums.TaskStatus.Cancelled    => "<span class='tp-badge tp-badge-cancelled'>Cancelled</span>",
        _ => s.ToString()
    };
    string PriorityBadge(TaskPilot.Models.Enums.TaskPriority p) => p switch {
        TaskPilot.Models.Enums.TaskPriority.Critical => "<span class='tp-badge tp-badge-critical'>Critical</span>",
        TaskPilot.Models.Enums.TaskPriority.High     => "<span class='tp-badge tp-badge-high'>High</span>",
        TaskPilot.Models.Enums.TaskPriority.Medium   => "<span class='tp-badge tp-badge-medium'>Medium</span>",
        TaskPilot.Models.Enums.TaskPriority.Low      => "<span class='tp-badge tp-badge-low'>Low</span>",
        _ => p.ToString()
    };
}

@section Scripts {
<script src="/lib/apexcharts/apexcharts.min.js"></script>
<script>
(function() {
    var weeklyData = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.Stats?.CompletedPerWeek?.Select(w => w.Count).ToList() ?? new List<int>()));
    var weeklyLabels = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.Stats?.CompletedPerWeek?.Select(w => w.WeekLabel).ToList() ?? new List<string>()));
    var priorityData = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.Stats?.ByPriority?.Select(p => p.NotStarted + p.InProgress + p.Blocked).ToList() ?? new List<int>()));
    var priorityLabels = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.Stats?.ByPriority?.Select(p => p.Priority).ToList() ?? new List<string>()));
    var typeData = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.Stats?.ByType?.Select(t => t.Count).ToList() ?? new List<int>()));
    var typeLabels = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.Stats?.ByType?.Select(t => t.Type).ToList() ?? new List<string>()));
    var topTagData = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.Stats?.TopTags?.Select(t => t.TaskCount).ToList() ?? new List<int>()));
    var topTagLabels = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.Stats?.TopTags?.Select(t => t.TagName).ToList() ?? new List<string>()));

    if (weeklyLabels.length > 0) {
        new ApexCharts(document.querySelector('#chart-weekly'), {
            chart: { type: 'bar', height: 200, toolbar: { show: false } },
            series: [{ name: 'Completed', data: weeklyData }],
            xaxis: { categories: weeklyLabels },
            colors: ['#6255EC'],
            plotOptions: { bar: { borderRadius: 4 } },
            dataLabels: { enabled: false }
        }).render();
    } else {
        document.querySelector('#chart-weekly').innerHTML = '<div class="tp-empty py-4"><div class="tp-empty-text">No data yet</div></div>';
    }

    if (priorityLabels.length > 0) {
        new ApexCharts(document.querySelector('#chart-priority'), {
            chart: { type: 'donut', height: 200 },
            series: priorityData,
            labels: priorityLabels,
            colors: ['#ef4444','#f59e0b','#6255EC','#10b981'],
            legend: { position: 'bottom' },
            dataLabels: { enabled: false }
        }).render();
    } else {
        document.querySelector('#chart-priority').innerHTML = '<div class="tp-empty py-4"><div class="tp-empty-text">No data yet</div></div>';
    }

    if (typeLabels.length > 0) {
        new ApexCharts(document.querySelector('#chart-type'), {
            chart: { type: 'bar', height: 200, toolbar: { show: false } },
            plotOptions: { bar: { horizontal: true, borderRadius: 4 } },
            series: [{ name: 'Tasks', data: typeData }],
            xaxis: { categories: typeLabels },
            colors: ['#6255EC'],
            dataLabels: { enabled: false }
        }).render();
    } else {
        document.querySelector('#chart-type').innerHTML = '<div class="tp-empty py-4"><div class="tp-empty-text">No data yet</div></div>';
    }

    if (topTagLabels.length > 0) {
        new ApexCharts(document.querySelector('#chart-top-tags'), {
            chart: { type: 'bar', height: 150, toolbar: { show: false } },
            plotOptions: { bar: { horizontal: true, borderRadius: 4 } },
            series: [{ name: 'Tasks', data: topTagData }],
            xaxis: { categories: topTagLabels },
            colors: ['#6255EC'],
            dataLabels: { enabled: false }
        }).render();
    }
})();
</script>
}
